me:not-signed-in == true"},{"view":"github.codespaces.explorer","contents":"GitHub Codespaces no longer supports this extension version and/or this Visual Studio Code version. \n[Browse newer versions](command:github.codespaces.openExtension)","when":"codespaces:views-welcome:version-notification == Unsupported"},{"view":"github.codespaces.warnExplorer","contents":"GitHub Codespaces will soon no longer support this extension version and/or this Visual Studio Code version. \n[Browse newer versions](command:github.codespaces.openExtension)","when":"codespaces:views-welcome:version-notification == Deprecated"}],"views":{"remote":[{"id":"github.codespaces.explorer","name":"GitHub Codespaces","group":"targets@2","remoteName":"codespaces","when":"!isWeb || activeViewlet == workbench.view.remote"},{"id":"github.codespaces.warnExplorer","name":"Warning","when":"codespaces:views-welcome:version-notification == Deprecated","group":"details@1","remoteName":"codespaces"},{"id":"github.codespaces.performanceExplorer","name":"Codespace Performance","when":"codespaces:performance-explorer-enabled && codespaces:views-welcome:version-notification != Unsupported","group":"details@2","remoteName":"codespaces"}]},"resourceLabelFormatters":[{"scheme":"vscode-remote","authority":"codespaces+*","formatting":{"label":"${path}","separator":"/","tildify":true,"workspaceSuffix":"Codespaces"}}],"configuration":{"title":"GitHub Codespaces","type":"object","properties":{"github.codespaces.defaultExtensions":{"type":"array","description":"Default extensions to install in GitHub Codespaces","default":["GitHub.codespaces","GitHub.vscode-pull-request-github","Github.copilot"]},"github.codespaces.usePortForwardingServiceForHTTPS":{"type":"boolean","markdownDescription":"When enabled, HTTPS services will be forwarded through our port forwarding service instead of local TCP server.","default":true},"github.codespaces.showPerformanceExplorer":{"type":"boolean","description":"Display the Codespace Performance window in the Remote Explorer.","default":false,"scope":"application"},"github.codespaces.createCodespaceInNewWindow":{"type":"boolean","description":"When a codespace is created or connected, open it in a new window.","default":false,"scope":"application"},"github.codespaces.devcontainerChangedNotificationStyle":{"type":"string","default":"notification","description":"Select which type of notification to show when devcontainer content changes","enum":["none","notification","modal"],"enumDescriptions":["No notification when devcontainer changes","Standard toast notification when devcontainer changes","Modal dialog notification when devcontainer changes"]},"github.codespaces.showDisplayNameInRemoteIndicator":{"type":"boolean","description":"When enabled, the codespace display name will be shown in the remote indicator and title bar when connected to a codespace.","default":true,"scope":"application"},"github.codespaces.supportProxies":{"type":"boolean","markdownDescription":"Allows proxies to make `CONNECT` requests when connecting to codespaces.","default":false,"scope":"application"},"github.codespaces.authProvider":{"type":"string","markdownDescription":"The authentication provider to use for signing in to GitHub. Set to `github-enterprise` when connecting to a GitHub Enterprise Server or Proxima instance.  \n**Note**: Make sure to set the `GitHub-enterprise: Uri` first accordingly.","default":"github","enum":["github","github-enterprise"],"enumDescriptions":["Use GitHub.com authentication.","Use GitHub Enterprise authentication."]}}},"commands":[{"command":"github.codespaces.activate","title":"Activate","category":"Codespaces"},{"command":"github.codespaces.exportLogs","title":"Export Logs","category":"Codespaces"},{"command":"github.codespaces.addEnvironment","title":"Create New Codespace...","category":"Codespaces","icon":{"dark":"images/dark/add.svg","light":"images/light/add.svg"},"enablement":"!isWeb || remoteName != codespaces"},{"command":"github.codespaces.continueEditSessionInCodespace","title":"Create New Codespace...","category":"Codespaces","icon":"$(github)"},{"command":"github.codespaces.continueEditSessionInCodespaceWithJupyterServer","title":"Connect to Codespace...","category":"Codespaces","icon":"$(github)"},{"command":"github.codespaces.refresh","title":"Refresh","category":"Codespaces","icon":{"dark":"images/dark/refresh.svg","light":"images/light/refresh.svg"}},{"command":"github.codespaces.connect","title":"Connect to Codespace...","category":"Codespaces","icon":"$(plug)","enablement":"!isWeb || remoteName != codespaces"},{"command":"github.codespaces.disconnectEnvironment","title":"Disconnect","category":"Codespaces","icon":"$(debug-disconnect)","enablement":"remoteName == codespaces"},{"command":"github.codespaces.reloadServer","title":"Kill VS Code Server on Host...","category":"Codespaces"},{"command":"github.codespaces.shutdownEnvironment","title":"Stop Codespace","category":"Codespaces","icon":"$(primitive-square)"},{"command":"github.codespaces.disconnectSuspend","title":"Stop Current Codespace","category":"Codespaces"},{"command":"github.codespaces.changeMachineType","title":"Change Machine Type","category":"Codespaces"},{"command":"github.codespaces.deleteEnvironment","title":"Delete Codespace...","category":"Codespaces"},{"command":"github.codespaces.signIn","title":"Sign In","category":"Codespaces","enablement":"codespaces:isSignedIn != true && remoteName != codespaces"},{"command":"github.codespaces.openExtension","title":"Open Extension","category":"Codespaces"},{"command":"github.codespaces.openInNewWindow","title":"Open Codespace in New Window","category":"Codespaces","enablement":"!isWeb"},{"command":"github.codespaces.openInBrowser","title":"Open in Browser","category":"Codespaces","enablement":"!isWeb"},{"command":"github.codespaces.openInStable","title":"Open in VS Code Desktop","category":"Codespaces","enablement":"isWeb && remoteName == codespaces"},{"command":"github.codespa