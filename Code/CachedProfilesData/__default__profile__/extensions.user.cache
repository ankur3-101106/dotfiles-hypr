.enableSearch":{"type":["boolean","string"],"default":"default","description":"Enable the Windsurf Indexing Engine. This feature allows chat and autocomplete models to have full codebase awareness, significantly improving autocomplete and chat quality. It also allows natural language search of your codebase. \n\n When first enabled, Windsurf will consume about 25% of CPU while it indexes the workspace. This should take < 10 minutes depending on your workspace size, once per workspace. CPU usage will return to normal automatically.","enum":[true,"default",false],"enumDescriptions":["On","Default (defer to Windsurf's judgement)","Off"]},"codeium.searchMaxWorkspaceFileCount":{"type":"integer","default":5000,"description":"Conditional on indexing being enabled, Windsurf will attempt to index workspaces that have up to this many files. This file count ignores .gitignore and binary files. Raising this limit from default may lead to performance issues. Values 0 or below will be treated as unlimited."},"codeium.indexingRetentionPeriod":{"type":"integer","default":30,"description":"Indexed files that have not been accessed within this retention period in days will be removed."},"codeium.snoozeTime":{"type":"integer","default":60,"description":"Snooze time in minutes. After this amount of time, Windsurf autocomplete will resume globally."},"codeium.languageServerStartupTimeout":{"type":"integer","default":15,"description":"Time in seconds the language server will have to start before timeout."},"codeium.enableCommandSideHintEducation":{"type":"boolean","default":true,"description":"Show the Windsurf Command shortcut upon selecting multiple lines of text"},"codeium.enableCodeLens":{"type":["boolean","string"],"default":true,"description":"AI-powered inline action buttons in your editor.","enum":[true,"hide_x",false],"enumDescriptions":["Always show","Always show, but hide the x","Never show"]},"codeium.useSecretStorage":{"type":"boolean","default":true,"description":"Prefer using VS Code secrets over local storage for credentials."},"codeium.aggressiveShutdown":{"type":"boolean","default":false,"description":"Use this setting if the language server process doesn't exit after VS Code closes."},"codeium.enableExplainProblem":{"type":"boolean","default":true,"description":"AI Powered `Windsurf: Explain Problem` hover pop-up."},"codeium.enableInComments":{"type":"boolean","default":true,"description":"If true, Windsurf will provide autocomplete suggestions in comments."},"codeium.indexStoragePath":{"type":"string","default":"","description":"Custom absolute path to store Windsurf index data. Use in cases when the home directory is an NFS mount so the path is on local disk."},"codeium.disableSupercomplete":{"type":"boolean","default":false,"description":"Whether to disable Windsurf Supercomplete (Beta)."},"codeium.disableTabJump":{"type":"boolean","default":false,"description":"Disable tab to jump functionality."}}},"viewsContainers":{"activitybar":[{"id":"codeium","title":"Windsurf","icon":"assets/windsurf.svg"}]},"views":{"codeium":[{"type":"webview","id":"codeium.chatPanelView","name":"Windsurf","visibility":"visible"}]},"commands":[{"command":"codeium.provideAuthToken","title":"Windsurf: Provide Authentication Token"},{"command":"codeium.refreshUnauthedPanel","title":"Windsurf: Refresh Unauthed Panel"},{"command":"codeium.showPreviousCompletion","title":"Windsurf: Show Previous Completion"},{"command":"codeium.showNextCompletion","title":"Windsurf: Show Next Completion"},{"command":"codeium.toggleAutocompleteForCurrentLanguage","title":"Windsurf: Toggle Autocomplete for Current Language"},{"command":"codeium.toggleAutocompleteGlobally","title":"Windsurf: Toggle Autocomplete Globally"},{"command":"codeium.toggleSupercomplete","title":"Windsurf: Toggle Supercomplete"},{"command":"codeium.copyStatusToClipboard","title":"Windsurf: Copy Status to Clipboard"},{"command":"codeium.openProfile","title":"Windsurf: Open Profile","icon":"$(accounts-v