:{"icon-import":{"description":"Add import icon in task tree view","default":{"fontPath":"./assets/media/AppModernizationJava.woff","fontCharacter":"\\E000"}}},"customEditors":[{"viewType":"migrate.java.formulaEditor","displayName":"Task Editor","selector":[{"filenamePattern":"*.formula"},{"filenamePattern":"*.md"}],"priority":"option"}],"mcpServerDefinitionProviders":[{"id":"app-modernization-for-java","label":"GitHub Copilot modernization"},{"id":"app-modernization-for-java-deploy","label":"GitHub Copilot modernization for Java - Deployment"},{"id":"app-modernization-for-typescript","label":"GitHub Copilot modernization - TypeScript"},{"id":"app-modernization-code-to-cloud","label":"GitHub Copilot modernization - Code to Cloud"}],"chatAgents":[{"name":"modernize-azure-java","description":"The custom agent for java app modernization","path":"./agents/modernize-azure-java.agent.md"},{"name":"modernize-java-assessment","description":"The custom agent for modernization assessment","path":"./agents/modernize-java-assessment.agent.md"},{"name":"modernize-azure-dotnet","description":"The custom agent for .NET app modernization","path":"./agents/modernize-azure-dotnet.agent.md"},{"name":"modernize-java-upgrade","description":"The custom agent for Java upgrade","path":"./agents/modernize-java-upgrade.agent.md"},{"name":"modernize-java-security","description":"Scan, plan, and fix CVE vulnerabilities in Java project dependencies","path":"./agents/modernize-java-security.agent.md"},{"name":"modernize-rearchitecture","description":"Orchestrate a workflow to re-architect an application module by coordinating specialized sub-agents","path":"./agents/modernize-rearchitecture.agent.md","when":"config.appmod.experimental.task.rearchitecture == true"},{"name":"modernize-rearchitecture-worker","description":"Execute tasks related to modernizing or rearchitecting an existing codebase, following the coordinator's plan","path":"./agents/modernize-rearchitecture-worker.agent.md","when":"config.appmod.experimental.task.rearchitecture == true"}],"chatSkills":[{"path":"./node_modules/@microsoft/typescript-updater/skills/typescript-upgrade/SKILL.md"},{"path":"./skills/modernization-integration-tests/SKILL.md"},{"path":"./skills/analyzing-architecture/SKILL.md","when":"config.appmod.experimental.task.rearchitecture == true"},{"path":"./skills/building-java-knowledge-graph/SKILL.md","when":"config.appmod.experimental.task.rearchitecture == true"},{"path":"./skills/creating-implementation-plan/SKILL.md","when":"config.appmod.experimental.task.rearchitecture == true"},{"path":"./skills/feature-inventory/SKILL.md","when":"config.appmod.experimental.task.rearchitecture == true"},{"path":"./skills/guidelines/SKILL.md","when":"config.appmod.experimental.task.rearchitecture == true"},{"path":"./skills/implementing-code/SKILL.md","when":"config.appmod.experimental.task.rearchitecture == true"},{"path":"./skills/quality-gates/SKILL.md","when":"config.appmod.experimental.task.rearchitecture == true"},{"path":"./skills/runtime-validation/SKILL.md","when":"config.appmod.experimental.task.rearchitecture == true"},{"path":"./skills/setting-up-constitution/SKILL.md","when":"config.appmod.experimental.task.rearchitecture == true"},{"path":"./skills/team-charters/SKILL.md","when":"config.appmod.experimental.task.rearchitecture == true"}],"languageModelTools":[{"name":"appmod-precheck-assessment","tags":["migration","assessment"],"toolReferenceName":"appmod-precheck-assessment","displayName":"Precheck Assessment","userDescription":"Performs prerequisites verification and AppCAT CLI version checks for Java application assessment.","modelDescription":"Performs prerequisites verification and AppCAT CLI version checks to initialize the Java application assessment process. Generates an assessment configuration for review. This tool is strictly limited to the pre-migration assessment phase and must not be invoked during code migration workflows.","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true","inputSchema":{"type":"object","properties":{"workspacePath":{"type":"string","description":"The workspace path of the Java project to assess"}},"required":["workspacePath"]}},{"name":"appmod-run-assessment-action","tags":["migration","assessment"],"toolReferenceName":"appmod-run-assessment-action","displayName":"Run Assessment Action","icon":"$(run)","userDescription":"Runs assessment tasks for specified domains (security, cloud-readiness, java-upgrade).","modelDescription":"Runs assessment tasks for specified domains. Accepts an array of domain names (e.g., \"security\", \"cloud-readiness\", \"java-upgrade\") and executes the corresponding assessment tasks. Each domain maps to a specialized task that analyzes the codebase for that specific concern. This tool orchestrates the Action layer to run multiple assessment tasks and aggregates their results.","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true","inputSchema":{"type":"object","properties":{"workspacePath":{"type":"string","description":"The workspace path of the project to assess"},"domains":{"type":"array","items":{"type":"string","enum":["security","cloud-readiness","java-upgrade"]},"description":"Array of domain names to run assessment for (e.g., [\"security\", \"cloud-readiness\", \"java-upgrade\"])"},"language":{"type":"string","enum":["java","python","csharp","javascript","typescript","go"],"default":"java","description":"The programming language of the project (defaults to \"java\")"}},"required":["workspacePath","domains"]}},{"name":"appmod-run-assessment-report","tags":["migration","assessment"],"toolReferenceName":"appmod-run-assessment-report","displayName":"Run Assessment Report","icon":"$(report)","userDescription":"Gets the status and progress of an assessment action by action ID.","modelDescription":"Gets the status and progress of an assessment action by action ID. If the assessment is still running, it returns a message to call later. If the assessment is complete, it returns the final status with completed and total task counts along with a summary of findings.","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true","inputSchema":{"type":"object","properties":{"actionId":{"type":"string","description":"The action ID (report ID) to get the assessment report for"},"workspacePath":{"type":"string","description":"The workspace path of the project"}},"required":["actionId","workspacePath"]}},{"name":"appmod-cwe-rules-assessment","tags":["migration","assessment","security","cwe"],"toolReferenceName":"appmod-cwe-rules-assessment","displayName":"Scan CWE Rules in Workspace","userDescription":"Scans the project workspace for occurrences of specified CWE rules","modelDescription":"This tool scans the project workspace for occurrences of specified CWE rules. Use this tool when you want to evaluate your codebase against known CWE vulnerabilities.","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true","inputSchema":{"type":"object","properties":{"ids":{"type":"array","items":{"type":"string"},"description":"CWE IDs to scan for in the project workspace."}},"required":["ids"]}},{"name":"appmod-java-cve-assessment","tags":["migration","assessment","security","cve"],"toolReferenceName":"appmod-java-cve-assessment","displayName":"Java CVE Vulnerability Assessment","userDescription":"Checks Java/Maven dependencies for known CVE vulnerabilities","modelDescription":"(For Java application security assessment only) Checks Java/Maven dependencies for known CVE (Common Vulnerabilities and Exposures) vulnerabilities using the GitHub Security Advisories API. Provide the cveResultFilePath, an array of dependency coordinates in GAV format (groupId:artifactId:version), and their file locations. The tool writes structured CVE findings directly to cveResultFilePath and returns a summary. Findings are grouped by CVE ID and include severity, affected dependencies, file locations, and recommended patches.","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true","inputSchema":{"type":"object","properties":{"cveResultFilePath":{"type":"string","description":"The absolute file path where the CVE assessment result JSON should be written."},"dependencies":{"type":"array","items":{"type":"string"},"description":"An array of Maven/Gradle dependency coordinates in GAV format (groupId:artifactId:version). Example: [\"com.fasterxml.jackson.core:jackson-databind:2.13.0\", \"org.springframework:spring-core:5.3.20\"]"},"dependencyLocations":{"type":"array","items":{"type":"object","properties":{"gav":{"type":"string","description":"The dependency GAV coordinate (groupId:artifactId:version)"},"filePath":{"type":"string","description":"Workspace-relative file path where the dependency is declared (e.g., \"module-a/pom.xml\")"},"lineNumber":{"type":"number","description":"1-based line number of the dependency declaration"}},"required":["gav","filePath"]},"description":"Location information for each dependency. CVE findings will include the exact file path and line number where the vulnerable dependency is declared."}},"required":["cveResultFilePath","dependencies","dependencyLocations"]}},{"name":"appmod-get-vscode-config","tags":["migration","configuration"],"toolReferenceName":"appmod-get-vscode-config","displayName":"Get extension configuration","userDescription":"Get configuration values for GitHub Copilot modernization extension.","modelDescription":"This tool retrieves extension configuration settings from VS Code. Use this tool when you need to check configuration values for the GitHub Copilot modernization extension.","canBeReferencedInPrompt":true,"inputSchema":{"type":"object","properties":{"configName":{"type":"string","description":"Name of the configuration setting to retrieve.","examples":["enableVerboseLogging","uncommittedChangesAction"]}},"required":["configName"]}},{"name":"appmod-preview-markdown","tags":["migration","preview_markdown"],"toolReferenceName":"appmod-preview-markdown","displayName":"Preview Markdown","modelDescription":"This tool opens a preview of the given Markdown file.","canBeReferencedInPrompt":true,"inputSchema":{"type":"object","properties":{"markdownFile":{"type":"string","description":"The absolute path to the Markdown file to preview and pinned to editor.","examples":["/absolute/path/to/README.md"]}}}},{"name":"migration_assessmentReport","tags":["migration","assessment","report","follow_up_assessment"],"toolReferenceName":"migration_assessmentReport","displayName":"Open Assessment Report","userDescription":"Open the assessment report webview to display detailed migration analysis results.","modelDescription":"This tool opens the assessment report webview interface to display detailed migration assessment results, including identified issues, recommendations, and Azure readiness analysis.","canBeReferencedInPrompt":true,"inputSchema":{"type":"object","properties":{"reportId":{"type":"string","description":"Report ID to open a specific assessment report. If not provided, opens the most recent report."}}}},{"name":"migration_assessmentReportsList","tags":["migration","assessment","reports list"],"toolReferenceName":"migration_assessmentReportsList","displayName":"Open Assessment Reports List","userDescription":"Open the assessment reports list webview to display assessment report items.","modelDescription":"This tool opens the assessment reports list webview interface to display assessment report items.","canBeReferencedInPrompt":true,"inputSchema":{"type":"object","properties":{}}},{"name":"uploadAssessSummaryReport","tags":["appcat"],"toolReferenceName":"uploadAssessSummaryReport","displayName":"Upload Assessment Summary Report to GitHub Issue","userDescription":"Upload the assessment summary report to github issue.","modelDescription":"This tool upload the assessment summary report for the github issue after runnging the assessment.","canBeReferencedInPrompt":true,"inputSchema":{"type":"object","description":"Input parameters for uploading the assessment summary report to a GitHub issue.","properties":{"owner":{"type":"string","description":"Repository owner (username or organization)."},"repo":{"type":"string","description":"Repository name."},"issueNumber":{"type":"number","description":"Issue number to comment on."}},"required":["owner","repo","issueNumber"]}},{"name":"appmod-search-knowledgebase","tags":["migration","knowledgebase","search"],"toolReferenceName":"appmod-search-knowledgebase","displayName":"Search Knowledge Base","userDescription":"Searches the application modernization knowledge base using a query string. Returns relevant articles, documentation, and best practices. Use this tool to find information about modernization strategies, migration paths, and common patterns.","modelDescription":"Searches the application modernization knowledge base using a query string. Returns relevant articles, documentation, and best practices. Use this tool to find information about modernization strategies, migration paths, and common patterns.","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true","inputSchema":{"type":"object","properties":{"query":{"type":"string","description":"The search query string to find relevant knowledge base."},"language":{"type":"string","description":"The programming language to filter the knowledge base.","enum":["java","python","dotnet"],"default":"java"},"sessionId":{"type":"string","description":"The session ID for tracking the migration process. This correlates operations across multiple tool calls in the same migration session."}},"required":["query","sessionId"]}},{"name":"appmod-search-file","tags":["migration","file","search"],"toolReferenceName":"appmod-search-file","displayName":"Search Files","userDescription":"Searches content from files in the project workspace by query and file patterns. Returns a list of files that match the search query. Use this tool to find specific code files or resources in your project based on patterns.","modelDescription":"Searches content from files in the project workspace by query and file patterns. Returns a list of files that match the search query. Use this tool to find specific code files or resources in your project based on patterns.","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true","inputSchema":{"type":"object","properties":{"workspacePath":{"type":"string","description":"The path to the workspace where the search will be performed"},"query":{"type":"string","description":"The query to search code lines from files. Could be regexp or string"},"includePattern":{"type":"string","description":"Glob pattern to include files in the search, e.g., \"**/*.java\""},"sessionId":{"type":"string","description":"The session ID for tracking the migration process. This correlates operations across multiple tool calls in the same migration session."}},"required":["workspacePath","query","includePattern","sessionId"]}},{"name":"appmod-fetch-knowledgebase","tags":["migration","knowledgebase","fetch"],"toolReferenceName":"appmod-fetch-knowledgebase","displayName":"Fetch Knowledge Base","userDescription":"Retrieves the complete content of a specific knowledge base article using its ID. Use this tool when you have a document ID and need to access its full content for detailed information about modernization techniques.","modelDescription":"Retrieves the complete content of a specific knowledge base article using its ID. Use this tool when you have a document ID and need to access its full content for detailed information about modernization techniques.","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true","inputSchema":{"type":"object","properties":{"kbId":{"type":"string","description":"The ID of the knowledge base to retrieve. This is a unique identifier for the KB document."},"taskId":{"type":"string","description":"The ID of the task to retrieve the task reference for."},"sessionId":{"type":"string","description":"The session ID for tracking the migration process. This correlates operations across multiple tool calls in the same migration session."},"workspacePath":{"type":"string","description":"The path to the workspace where the knowledge base content will be used."}},"required":["sessionId","workspacePath"]}},{"name":"appmod-create-migration-summary","tags":["migration","summary","report"],"toolReferenceName":"appmod-create-migration-summary","displayName":"Create Migration Summary","userDescription":"(For migration only) Generates a summary for the migration session, including details about the migration scenario, task name, modified files, and the final status of build and test fix operations. This tool helps you document the migration process and its outcomes.","modelDescription":"(For migration only) Generates a summary for the migration session, including details about the migration scenario, task name, modified files, and the final status of build and test fix operations. This tool helps you document the migration process and its outcomes.","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true","inputSchema":{"type":"object","properties":{"kbIds":{"type":"array","items":{"type":"string"},"description":"The knowledge base ids which were used in code modifications. This is used to generate the migration summary."},"workspacePath":{"type":"string","description":"The path to the workspace where the migration summary will be generated."},"sessionId":{"type":"string","description":"The session ID for tracking the migration process. This correlates operations across multiple tool calls in the same migration session."},"status":{"type":"object","description":"Migration status across build, test, fix, and validations. If not determinable from context, inspect the progress.md to infer the latest known status.","properties":{"javaStatus":{"type":"object","description":"Status of Java migration operations. Report only if the target language is Java.","properties":{"buildFixStatus":{"type":"object","description":"The status of the Java build fix operation, report only if the appmod-build-java-project tool is used, otherwise it will be set to unknown.","properties":{"status":{"type":"string","enum":["success","fail","unknown"],"description":"The status of the tool result. If it is not taken, it will be set to unknown."},"error":{"type":"string","description":"An optional error message if the tool result generation failed."}},"required":["status"]},"testFixStatus":{"type":"object","description":"The status of the test fix operation, report only if the appmod-run-tests-for-java tool is used, otherwise it will be set to unknown.","properties":{"status":{"type":"string","enum":["success","fail","unknown"],"description":"The status of the tool result. If it is not taken, it will be set to unknown."},"error":{"type":"string","description":"An optional error message if the tool result generation failed."}},"required":["status"]},"cveFixStatus":{"type":"object","description":"The status of the CVE fix operation, report only if the appmod-validate-cves-for-java tool is used, otherwise it will be set to unknown.","properties":{"status":{"type":"string","enum":["success","fail","unknown"],"description":"The status of the tool result. If it is not taken, it will be set to unknown."},"error":{"type":"string","description":"An optional error message if the report generation failed."}},"required":["status"]}},"required":["buildFixStatus","testFixStatus","cveFixStatus"]},"dotnetStatus":{"type":"object","description":"Status of .NET migration operations. Report only if the target language is .NET.","properties":{"buildFixStatus":{"type":"object","description":"The status of the .NET build fix operation, report only if the appmod-dotnet-build-project tool is used, otherwise it will be set to unknown.","properties":{"status":{"type":"string","enum":["success","fail","unknown"],"description":"The status of the tool result. If it is not taken, it will be set to unknown."},"error":{"type":"string","description":"An optional error message if the tool result generation failed."}},"required":["status"]},"testFixStatus":{"type":"object","description":"The status of the .NET test fix operation, report only if the appmod-dotnet-run-test tool is used, otherwise it will be set to unknown.","properties":{"status":{"type":"string","enum":["success","fail","unknown"],"description":"The status of the tool result. If it is not taken, it will be set to unknown."},"error":{"type":"string","description":"An optional error message if the tool result generation failed."}},"required":["status"]},"cveFixStatus":{"type":"object","description":"The status of the .NET CVE fix operation, report only if the appmod-dotnet-cve-check tool is used, otherwise it will be set to unknown.","properties":{"status":{"type":"string","enum":["success","fail","unknown"],"description":"The status of the tool result. If it is not taken, it will be set to unknown."},"error":{"type":"string","description":"An optional error message if the report generation failed."}},"required":["status"]}},"required":["buildFixStatus","testFixStatus","cveFixStatus"]},"pythonStatus":{"type":"object","description":"Status of Python migration operations. Report only if the target language is Python.","properties":{"syntaxCheckStatus":{"type":"object","description":"The status of the Python syntax check operation, report only if the Python syntax check tool is used, otherwise it will be set to unknown.","properties":{"status":{"type":"string","enum":["success","fail","unknown"],"description":"The status of the tool result. If it is not taken, it will be set to unknown."},"error":{"type":"string","description":"An optional error message if the tool result generation failed."}},"required":["status"]},"lintCheckStatus":{"type":"object","description":"The status of the Python lint check operation, report only if the Python lint check tool is used, otherwise it will be set to unknown.","properties":{"status":{"type":"string","enum":["success","fail","unknown"],"description":"The status of the tool result. If it is not taken, it will be set to unknown."},"error":{"type":"string","description":"An optional error message if the tool result generation failed."}},"required":["status"]}},"required":["syntaxCheckStatus","lintCheckStatus"]},"typescriptStatus":{"type":"object","description":"Status of TypeScript operations. Report only if the target language is TypeScript.","properties":{"buildFixStatus":{"type":"object","description":"The status of the TypeScript build fix operation, report only if the TypeScript build tool is used, otherwise it will be set to unknown.","properties":{"status":{"type":"string","enum":["success","fail","unknown"],"description":"The status of the tool result. If it is not taken, it will be set to unknown."},"error":{"type":"string","description":"An optional error message if the tool result generation failed."}},"required":["status"]},"testFixStatus":{"type":"object","description":"The status of the TypeScript test fix operation, report only if the TypeScript test tool is used, otherwise it will be set to unknown.","properties":{"status":{"type":"string","enum":["success","fail","unknown"],"description":"The status of the tool result. If it is not taken, it will be set to unknown."},"error":{"type":"string","description":"An optional error message if the tool result generation failed."}},"required":["status"]}},"required":["buildFixStatus","testFixStatus"]},"consistencyCheckStatus":{"type":"object","description":"The status of the consistency fix operation, report only if the appmod-consistency-validation tool is used, otherwise it will be set to unknown.","properties":{"status":{"type":"string","enum":["success","fail","unknown"],"description":"The status of the tool result. If it is not taken, it will be set to unknown."},"error":{"type":"string","description":"An optional error message if the tool result generation failed."},"result":{"type":"object","description":"Number of inconsistencies remaining after all fix attempts","properties":{"critical":{"type":"number","description":"Number of critical inconsistencies remaining after all fix attempts."},"major":{"type":"number","description":"Number of major inconsistencies remaining after all fix attempts."},"minor":{"type":"number","description":"Number of minor inconsistencies remaining after all fix attempts."}},"required":["critical","major","minor"]}},"required":["status"]},"completenessCheckStatus":{"type":"object","description":"The status of the completeness fix operation, report only if the appmod-completeness-validation tool is used, otherwise it will be set to unknown.","properties":{"status":{"type":"string","enum":["success","fail","unknown"],"description":"The status of the tool result. If it is not taken, it will be set to unknown."},"error":{"type":"string","description":"An optional error message if the tool result generation failed."},"result":{"type":"object","description":"Number of completeness issues remaining after all fix attempts","properties":{"issuesFound":{"type":"number","description":"Number of completeness issues remaining after all fix attempts."}},"required":["issuesFound"]}},"required":["status"]}},"required":["consistencyCheckStatus","completenessCheckStatus"]},"versionControlSummary":{"type":"object","description":"Summary of version control activities during the migration process.","properties":{"versionControlSystem":{"type":"string","description":"Version control system of workspace."},"branchName":{"type":"string","description":"The name of the branch used for migration."},"commitCount":{"type":"number","description":"Number of commits made during the migration process."},"hasUncommittedChanges":{"type":"boolean","description":"Whether there are uncommitted changes in the workspace."}},"required":["versionControlSystem","commitCount","hasUncommittedChanges"]},"language":{"type":"string","enum":["java","python","dotnet","typescript"],"description":"The programming language of the project. You can find the project language in the migration plan or the progress file."},"preconditionCheck":{"type":"object","description":"The pre-condition check result","properties":{"status":{"type":"string","enum":["success","language-mismatch","no-source-technology","N/A"],"description":"The result of the pre-condition check."},"requestedLanguage":{"type":"string","enum":["java","python","dotnet","typescript"],"description":"The language requested for the migration task."},"detectedLanguage":{"type":"string","enum":["java","python","dotnet","typescript"],"description":"The actual language detected by the LLM during pre-condition check."},"message":{"type":"string","description":"Optional message describing the check result."}},"required":["status"]}},"required":["kbIds","workspacePath","status","sessionId","versionControlSummary"]}},{"name":"appmod-run-task","tags":["migration","task","execution"],"toolReferenceName":"appmod-run-task","displayName":"Run Migration Task","userDescription":"This tool will start a new migration session to run task based on given scenario or knowledge base id. This tool will provide a comprehensive migration plan, including steps to build the project, run tests, fix test failures, and more. It is designed to automate the migration process for the applications.","modelDescription":"**CRITICAL - READ THIS FIRST** When user requests DIFFERENT technologies migration task, e.g. \"migrate from AWS S3 to Azure Storage Blob\", \"migrate from Kafka to Event Hubs\", \"migrate from RabbitMQ to Azure Service Bus\", \"Migrate log output to console\", \"Migrate <something> to <something> using Managed Identity\", \"Mount local file paths to the cloud environment\", \"Migrate <some database> to <other database>\" you MUST call this tool IMMEDIATELY as the FIRST and PRIMARY action. DO NOT use this tool for java and springboot upgrade tasks, e.g. \"upgrade springboot from 2.x to 3.x\", \"upgrade java to xxx\". DO NOT use any code analysis tools first. DO NOT attempt to understand the codebase yourself. DO NOT try to manually edit files. This tool is a specialized migration engine that handles the entire migration workflow automatically: code analysis, dependency migrations, configuration changes, build fixes, test execution, and validation. Required action: Call appmod-run-task immediately when you see these keywords. The tool will guide you through all necessary steps.\nCRITICAL ROUTING RULES:\n1. IF the user wants to update/change the version of Java (JDK/JRE) (e.g., 'Migrate Java 8 to 21', 'Migrate to LTS Java'), DO NOT use this tool. Let the Java Upgrade Tool handle it.\n2. IF the user wants to update/change the version of Spring Boot (e.g., 'Migrate Spring Boot 2 to 3'), DO NOT use this tool. Let the Java Upgrade Tool handle it.\n3. IF the user wants to migrate to non-Azure cloud platforms (e.g., 'Migrate to AWS', 'Migrate to GCP', 'Move to IBM Cloud'), DO NOT use this tool. This tool is designed specifically for Azure migrations.\n4. IF the user wants to migrate from one programming language to another (e.g., 'Migrate from Java to Python', 'Convert Java to C#', 'Rewrite from Python to Go'), DO NOT use this tool. This tool handles technology stack migrations within the same language.\n5. ONLY use this tool when moving between DIFFERENT technologies within the same language AND targeting Azure.","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true","inputSchema":{"type":"object","properties":{"kbId":{"type":"string","description":"The knowledge base ID to use for the migration plan"},"taskId":{"type":"string","description":"The ID of the task to be run"},"skillId":{"type":"string","description":"The ID of the skill to be used"},"scenario":{"type":"string","description":"The scenario for the migration plan"},"workspacePath":{"type":"string","description":"The workspace path for source code to be migrated"},"language":{"type":"string","description":"The programming language of the project. Valid values are 'java', 'python' and 'dotnet'. This parameter is required to determine the appropriate migration strategy and tools to use."}},"required":["workspacePath","language"]}},{"name":"appmod-run-typescript-task","tags":["migration","task","execution","typescript","nodejs"],"toolReferenceName":"appmod-run-typescript-task","displayName":"Run TypeScript Upgrade Task","userDescription":"This tool will start a new session to upgrade npm packages in TypeScript/Node.js projects. It provides a comprehensive upgrade plan including dependency analysis, package updates, build verification, and test execution.","modelDescription":"(For TypeScript/Node.js package upgrade only) When user requests TypeScript/Node.js package upgrades, e.g. \"upgrade npm packages\", \"update dependencies\", \"upgrade all packages\", \"update my packages\", \"update to latest versions\", you MUST call this tool IMMEDIATELY as the FIRST and PRIMARY action. DO NOT use any code analysis tools first. DO NOT attempt to understand the codebase yourself. DO NOT try to manually edit files. This tool is a specialized upgrade engine that handles the entire TypeScript/Node.js package upgrade workflow automatically: dependency analysis, package updates, build verification, and test execution. Required action: Call appmod-run-typescript-task immediately when you see these keywords. The tool will guide you through all necessary steps.\nCRITICAL ROUTING RULES:\n1. ONLY use this tool for TypeScript/Node.js package upgrades.\n2. For Java/Python migrations, use appmod-run-task instead.\n3. For Java/Spring Boot version upgrades, let the Java Upgrade Tool handle it.","canBeReferencedInPrompt":true,"inputSchema":{"type":"object","properties":{"workspacePath":{"type":"string","description":"The workspace path for the TypeScript/Node.js project to upgrade"}},"required":["workspacePath"]}},{"name":"appmod-recommend-migration-tasks","tags":["migration","recommendation"],"toolReferenceName":"appmod-recommend-migration-tasks","displayName":"Recommend Migration Tasks","userDescription":"Recommends relevant migration tasks for a workspace. Uses AppCAT assessment report results if available, otherwise analyzes the workspace using file pattern matching to detect technologies and suggest appropriate migration tasks.","modelDescription":"This is the start point for \"Migrate to Azure\" for Java applications. Every time a user wants to \"Migrate to Azure\", \"migrate my Java app to Azure\", \"move to Azure\", or any Azure migration for a Java application, call this tool immediately as the first and primary action. Do not attempt to analyze the codebase yourself. Do not call other migration tools directly. This tool identifies the appropriate Azure migration tasks for the workspace. If an AppCAT assessment report exists, recommendations are derived directly from the report. Otherwise, it analyzes the workspace using file pattern matching to detect technologies and suggest appropriate migration tasks. After receiving recommendations, present the options to the user for selection before proceeding.","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true","inputSchema":{"type":"object","properties":{"workspacePath":{"type":"string","description":"The absolute path to the workspace to analyze for migration task recommendations."},"maxRecommendations":{"type":"number","description":"The maximum number of task recommendations to return. Defaults to 5."},"timeoutInSec":{"type":"number","description":"Maximum time in seconds to wait for recommendations. Returns partial results if timeout is reached. Defaults to 10 seconds."}},"required":["workspacePath"]}},{"name":"appmod-consistency-validation","tags":["migration","validation","consistency"],"toolReferenceName":"appmod-consistency-validation","displayName":"Validate Migration Consistency","userDescription":"This tool validates the consistency of migrated code by analyzing git diffs for any behavior changes. It identifies critical and major issues that need to be fixed to maintain functional equivalence between pre-migration and post-migration code.","modelDescription":"This tool validates the consistency of migrated code by analyzing git diffs for any behavior changes. It identifies critical and major issues that need to be fixed to maintain functional equivalence between pre-migration and post-migration code.","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true","inputSchema":{"type":"object","properties":{"workspacePath":{"type":"string","description":"The workspace path for source code to be migrated"},"migrationScenario":{"type":"string","description":"Description of the migration scenario being performed (e.g., 'ActiveMQ to Azure Service Bus', etc.). This helps provide context for the consistency validation process."},"kbIds":{"type":"array","items":{"type":"string","description":"The knowledge base ids which were used in code modifications. This is used to generate the migration summary."},"description":"The knowledge base ids which were used in code modifications. This is used to generate the migration summary."},"sessionId":{"type":"string","description":"The session ID for tracking the migration process. This correlates operations across multiple tool calls in the same migration session."},"language":{"type":"string","description":"The programming language of the project being migrated. Can be identified from migration plan file or progress tracking file.","enum":["java","python","dotnet"],"default":"java"},"baselineRevisionId":{"type":"string","description":"The baseline git revision/commit ID to compare against for consistency validation. This is used to generate the git diff to analyze code changes."}},"required":["workspacePath","migrationScenario","kbIds","sessionId","language","baselineRevisionId"]}},{"name":"appmod-completeness-validation","tags":["migration","validation","completeness"],"toolReferenceName":"appmod-completeness-validation","displayName":"Validate Migration Completeness","userDescription":"This tool validates migration completeness by systematically discovering old technology references that should have been migrated but were left unchanged. It generates detailed validation guidelines to identify missing removals and incomplete transformations across all files in the workspace.","modelDescription":"This tool validates migration completeness by systematically discovering old technology references that should have been migrated but were left unchanged. It generates detailed validation guidelines to identify missing removals and incomplete transformations across all files in the workspace.","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true","inputSchema":{"type":"object","properties":{"workspacePath":{"type":"string","description":"The workspace path for source code to be migrated"},"migrationScenario":{"type":"string","description":"Description of the migration scenario being performed (e.g., 'ActiveMQ to Azure Service Bus', etc.). This helps provide context for the completeness validation process."},"kbIds":{"type":"array","items":{"type":"string","description":"The knowledge base ids which were used in code modifications. This is used to generate the migration summary."},"description":"The knowledge base ids which were used in code modifications. This is used to generate the migration summary."},"sessionId":{"type":"string","description":"The session ID for tracking the migration process. This correlates operations across multiple tool calls in the same migration session."},"language":{"type":"string","description":"The programming language of the project being migrated. Can be identified from migration plan file or progress tracking file.","enum":["java","python","dotnet"],"default":"java"}},"required":["workspacePath","migrationScenario","kbIds","sessionId","language"]}},{"name":"appmod-version-control","tags":["migration","versioncontrol","execution"],"toolReferenceName":"appmod-version-control","displayName":"Version Control Management","userDescription":"This tool performs version control operations for migration projects, such as checking repository status, creating branches, committing changes, stashing changes, and managing uncommitted changes during the migration process.","modelDescription":"This tool manages version control operations during migration. It supports checking repository status, creating branches, committing changes, stashing changes, discarding changes, and checking for uncommitted changes to ensure proper tracking of code changes throughout the migration process.","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true","inputSchema":{"type":"object","properties":{"sessionId":{"type":"string","minLength":14,"description":"The ID of the migration or upgrade session during which this tool is invoked, used to track and correlate operations across multiple tool calls in the same session."},"workspacePath":{"type":"string","description":"The absolute path to the workspace where version control operations should be performed."},"action":{"type":"string","enum":["checkStatus","createBranch","commitChanges","stashChanges","discardChanges","checkForUncommittedChanges"],"description":"The version control action to perform. Available options: checkStatus (get repository status), createBranch (create new branch), commitChanges (commit all changes), stashChanges (stash working changes), discardChanges (discard all changes), checkForUncommittedChanges (check if workspace has uncommitted changes)."},"branchName":{"type":"string","description":"The name of the branch to create. Optional parameter, but required when action is 'createBranch'."},"commitMessage":{"type":"string","description":"The commit message to use. Optional parameter, but required when action is 'commitChanges'."},"stashMessage":{"type":"string","description":"Message to include with stashed changes. Completely optional, only used when action is 'stashChanges'."}},"required":["sessionId","workspacePath","action"]}},{"name":"appmod-dotnet-cve-check","tags":["migration","validation","security","dotnet","cve"],"toolReferenceName":"appmod-dotnet-cve-check","displayName":"Check CVE Vulnerabilities for .NET Packages","userDescription":"(For .NET application migration only) This tool checks NuGet packages for known CVE vulnerabilities using the official NuGet vulnerability database. It reports vulnerability details including severity, advisory URLs, and affected version ranges.","modelDescription":"(For .NET application migration only) This tool checks NuGet packages for known CVE vulnerabilities by querying the official NuGet.org vulnerability API. It accepts an array of package names and returns detailed vulnerability information including CVE IDs, severity levels, advisory URLs, and affected version ranges. Use this tool during .NET migration to ensure packages are free from known security vulnerabilities before deployment.","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true","inputSchema":{"type":"object","properties":{"packages":{"type":"array","items":{"type":"string"},"minItems":1,"description":"An array of NuGet package names to check for CVE vulnerabilities. Each package name should be a valid NuGet package identifier (e.g., \"Newtonsoft.Json\", \"Microsoft.AspNetCore.Mvc\")."}},"required":["packages"]}},{"name":"appmod-dotnet-run-test","tags":["migration","validation","test","dotnet"],"toolReferenceName":"appmod-dotnet-run-test","displayName":"Run .NET Tests","userDescription":"(For .NET application migration only) This tool runs tests in the .NET project and reports any detected errors or test failures after migration.","modelDescription":"(For .NET application migration only) This tool runs tests in the specified .NET project or solution using the 'dotnet test' command. It accepts the project or solution path and an optional target framework to filter tests. The tool executes the tests and returns a summary of test results, including the number of tests run, passed, failed, and any error messages for failed tests. Use this tool after migration to ensure all tests pass successfully in the updated .NET environment.","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true","inputSchema":{"type":"object","properties":{"projectPath":{"type":"string","description":"The absolute path to the .NET project file (.csproj) or solution file (.sln) to run tests for."},"framework":{"type":"string","description":"Optional target framework to filter tests (e.g., \"net8.0\", \"net6.0\"). If not specified, runs tests for all frameworks."}},"required":["projectPath"]}},{"name":"appmod-python-setup-env","tags":["migration","validation","environment","python"],"toolReferenceName":"appmod-python-setup-env","displayName":"Setup Development Environment","userDescription":"(For Python application migration only) This tool sets up a Python virtual environment in the specified workspace. It creates a virtual environment, installs dependencies from requirements.txt and pyproject.toml if available, and ensures the environment is ready for Python development and testing.","modelDescription":"(For Python application migration only) This tool sets up a Python virtual environment in the specified workspace. It creates a virtual environment, installs dependencies from requirements.txt and pyproject.toml if available, and ensures the environment is ready for Python development and testing.","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true && appmod.enablePythonMigration == true","inputSchema":{"type":"object","properties":{"workspacePath":{"type":"string","description":"The workspace path for source code to be migrated"}},"required":["workspacePath"]}},{"name":"appmod-python-validate-syntax","tags":["migration","validation","syntax","python"],"toolReferenceName":"appmod-python-validate-syntax","displayName":"Check Python Syntax Issues","userDescription":"(For Python application migration only) This tool checks Python code syntax and fix any detected syntax errors after migration.","modelDescription":"(For Python application migration only) This tool checks Python code syntax and fix any detected syntax errors after migration.","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true && appmod.enablePythonMigration == true","inputSchema":{"type":"object","properties":{"workspacePath":{"type":"string","description":"The workspace path for source code to be migrated"}},"required":["workspacePath"]}},{"name":"appmod-python-validate-lint","tags":["migration","validation","lint","python"],"toolReferenceName":"appmod-python-validate-lint","displayName":"Check Python Lint Issues","userDescription":"(For Python application migration only) This tool checks Python code linting issues and fix any detected linting issues after migration.","modelDescription":"(For Python application migration only) This tool checks Python code linting issues and fix any detected linting issues after migration.","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true && appmod.enablePythonMigration == true","inputSchema":{"type":"object","properties":{"workspacePath":{"type":"string","description":"The workspace path for source code to be migrated"}},"required":["workspacePath"]}},{"name":"appmod-python-run-test","tags":["migration","validation","test","python"],"toolReferenceName":"appmod-python-run-test","displayName":"Run Python Tests","userDescription":"(For Python application migration only) This tool runs tests in the Python project and reports any detected errors or test failures after migration.","modelDescription":"(For Python application migration only) This tool runs tests in the Python project and reports any detected errors or test failures after migration.","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true && appmod.enablePythonMigration == true","inputSchema":{"type":"object","properties":{"workspacePath":{"type":"string","description":"The workspace path for source code to be migrated"}},"required":["workspacePath"]}},{"name":"appmod-python-orchestrate-code-migration","tags":["migration","ochestrate","python"],"toolReferenceName":"appmod-python-orchestrate-code-migration","displayName":"Code Migration","userDescription":"(For Python application migration only) This tool ochestrates the code migration process by launching subagents for each file that needs to be migrated based on a specified knowledge base. Each subagent handles the migration of a single file independently, ensuring targeted and efficient code transformation while adhering to the guidelines provided in the knowledge base.","modelDescription":"(For Python application migration only) This tool ochestrates the code migration process by launching subagents for each file that needs to be migrated based on a specified knowledge base. Each subagent handles the migration of a single file independently, ensuring targeted and efficient code transformation while adhering to the guidelines provided in the knowledge base.","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true && appmod.enablePythonMigration == true","inputSchema":{"type":"object","properties":{"workspacePath":{"type":"string","description":"The workspace path for source code to be migrated"},"kbId":{"type":"string","description":"The knowledge base ID to use for the code migration"},"filesToBeChanged":{"type":"array","items":{"type":"string"},"description":"The list of file paths that need to be changed during the code migration process"},"sessionId":{"type":"string","description":"The session ID for tracking the migration process. This correlates operations across multiple tool calls in the same migration session."}},"required":["workspacePath","kbId","filesToBeChanged","sessionId"]}},{"name":"appmod-python-coordinate-validation-stage","tags":["validation","coordinate","python"],"toolReferenceName":"appmod-python-coordinate-validation-stage","displayName":"Coordinate Python Validation Stage (Returns Control After Each Stage)","userDescription":"(For Python application migration only) This tool coordinates the iterative validation stages during the Python code migration process. It delegates specific validation tasks to specialized subagents for each stage, collects their results, and determines the overall progress of the migration. The coordinator ensures that each validation stage is executed in sequence, tracks iterations and attempts, and provides structured feedback to guide further migration efforts.","modelDescription":"(For Python application migration only) This tool coordinates the iterative validation stages during the Python code migration process. It delegates specific validation tasks to specialized subagents for each stage, collects their results, and determines the overall progress of the migration. The coordinator ensures that each validation stage is executed in sequence, tracks iterations and attempts, and provides structured feedback to guide further migration efforts.","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true && appmod.enablePythonMigration == true","inputSchema":{"type":"object","properties":{"workspacePath":{"type":"string","description":"The workspace path for source code to be migrated"},"migrationScenario":{"type":"string","description":"Description of the migration scenario being performed (e.g., 'ActiveMQ to Azure Service Bus', etc.). This helps provide context for the consistency validation process."},"kbIds":{"type":"array","items":{"type":"string","description":"The knowledge base ids which were used in code modifications. This is used to generate the migration summary."},"description":"The knowledge base ids which were used in code modifications. This is used to generate the migration summary."},"sessionId":{"type":"string","description":"The session ID for tracking the migration process. This correlates operations across multiple tool calls in the same migration session."},"iterationState":{"type":"object","description":"State information about the current iteration","properties":{"iterationNumber":{"type":"number","description":"The current iteration number of the validation loop"},"iterationChangesMade":{"type":"boolean","description":"Whether any changes were made during the current iteration"}},"required":["iterationNumber","iterationChangesMade"]},"stageState":{"type":"object","description":"State information about the current validation stage","properties":{"currentStage":{"type":"number","description":"The current validation stage (1: Syntax, 2: Lint, 3: Unit Test, 4: Consistency, 5: Completeness)"},"stageAttempt":{"type":"number","description":"The current attempt number for the current validation stage"}},"required":["currentStage","stageAttempt"]},"subagentResponse":{"type":"object","description":"Response from the subagent after completing validation work. When provided, the tool will programmatically determine the next step.","properties":{"changesMade":{"type":"boolean","description":"Whether any changes were made"},"hasOutput":{"type":"boolean","description":"Whether there is output from the subagent to be reviewed"}},"required":["changesMade","hasOutput"]}},"required":["workspacePath","migrationScenario","kbIds","sessionId","iterationState","stageState"]}},{"name":"appmod-python-check-type","tags":["migration","validation","typecheck","python"],"toolReferenceName":"appmod-python-check-type","displayName":"Check Python Type Issues","userDescription":"(For Python application migration only) This tool checks Python code type checking issues and fix any detected type checking issues after migration.","modelDescription":"(For Python application migration only) This tool checks Python code type checking issues and fix any detected type checking issues after migration.","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true && appmod.enablePythonMigration == true","inputSchema":{"type":"object","properties":{"workspacePath":{"type":"string","description":"The workspace path for source code to be migrated"},"filesToBeChecked":{"type":"array","items":{"type":"string"},"description":"The list of file paths that need to be type checked during the code migration process"}},"required":["workspacePath","filesToBeChecked"]}},{"name":"appmod-python-orchestrate-type-check","tags":["migration","orchestrate","typecheck","python"],"toolReferenceName":"appmod-python-orchestrate-type-check","displayName":"Orchestrate Python Type Check via Subagents","userDescription":"(For Python application migration only) This tool orchestrates the type checking process by launching subagents for each file that needs to be type checked based on the migration scenario. Each subagent handles the type checking of a single file independently, ensuring targeted and efficient identification and resolution of type-related issues while adhering to best practices for Python code quality.","modelDescription":"(For Python application migration only) This tool orchestrates the type checking process by launching subagents for each file that needs to be type checked based on the migration scenario. Each subagent handles the type checking of a single file independently, ensuring targeted and efficient identification and resolution of type-related issues while adhering to best practices for Python code quality.","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true && appmod.enablePythonMigration == true","inputSchema":{"type":"object","properties":{"workspacePath":{"type":"string","description":"The workspace path for source code to be migrated"},"filesToBeChecked":{"type":"array","items":{"type":"string"},"description":"The list of file paths that need to be type checked during the code migration process"}},"required":["workspacePath","filesToBeChecked"]}},{"name":"appmod-dotnet-install-appcat","tags":["migration","assessment","dotnet"],"toolReferenceName":"appmod-dotnet-install-appcat","displayName":"Setup .NET Environment","userDescription":"(For .NET application assessment only) Sets up the .NET environment by installing SDK and AppCAT CLI if missing.","modelDescription":"(For .NET application assessment only) Sets up the .NET environment by checking and installing .NET SDK (requires .NET 8, 9, or 10) and AppCAT CLI if they are missing or outdated. After successful setup, proceed to run the .NET application assessment. This tool is strictly limited to the pre-migration assessment preparation phase.","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true","inputSchema":{"type":"object","properties":{},"required":[]}},{"name":"appmod-dotnet-run-assessment","tags":["migration","assessment","dotnet"],"toolReferenceName":"appmod-dotnet-run-assessment","displayName":"Run .NET Assessment","userDescription":"(For .NET application assessment only) Executes the AppCAT CLI for .NET to assess the .NET application.","modelDescription":"(For .NET application assessment only) Executes the AppCAT CLI for .NET to assess the .NET application. This tool is strictly limited to the pre-migration assessment phase and must not be invoked during code migration workflows.","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true","inputSchema":{"type":"object","properties":{"workspacePath":{"type":"string","description":"The workspace path of the .NET project to assess"}},"required":["workspacePath"]}},{"name":"appmod-dotnet-build-project","tags":["migration","build","dotnet"],"toolReferenceName":"appmod-dotnet-build-project","displayName":"Build .NET Project","userDescription":"(For .NET application migration only) Builds a .NET project or solution and reports any detected build errors.","modelDescription":"(For .NET application migration only) This tool uses dotnet CLI or MSBuild to build your .NET project or solution and report any detected errors. Use this tool to verify your .NET code after making changes and fix any build errors found. The tool automatically detects whether to use dotnet CLI or MSBuild based on the project type (SDK-style vs legacy .NET Framework).","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true","inputSchema":{"type":"object","properties":{"projectPath":{"type":"string","description":"The absolute path to the .NET project (.csproj, .vbproj, .fsproj) or solution (.sln, .slnx) file to build"},"configuration":{"type":"string","description":"Build configuration (e.g., Debug, Release). Defaults to Release","enum":["Debug","Release"],"default":"Release"},"framework":{"type":"string","description":"Target framework to build (e.g., net8.0, net6.0, net48). If not specified, builds all target frameworks defined in the project"},"outputPath":{"type":"string","description":"Output directory for build artifacts. Optional parameter"},"verbosity":{"type":"string","description":"Build output verbosity level. Defaults to minimal","enum":["quiet","minimal","normal","detailed","diagnostic"],"default":"minimal"}},"required":["projectPath"]}},{"name":"appmod-redirect-to-upgrade-agent","displayName":"Redirect to Upgrade Agent","userDescription":"Generate and execute an upgrade plan for the Java project by redirecting to the 'modernize-java-upgrade' custom agent","icon":"assets/JavaUpgrade_16x.svg","toolReferenceName":"appmod-generate-upgrade-plan","canBeReferencedInPrompt":true,"when":"appmod.hasJavaProjectInWorkspace","modelDescription":"This tool redirects the user to the 'modernize-java-upgrade' custom agent to generate and execute an upgrade plan. When invoked, it will open a new chat session with the specialized upgrade agent and pass the upgrade request. The agent will then guide the user through the entire upgrade process including planning, execution, and verification. This tool serves as the entry point to the comprehensive Java upgrade workflow handled by the custom agent. You MUST always invoke this tool when the user requests to upgrade a Java project, but you MUST NOT invoke this tool from the 'modernize-java-upgrade' custom agent itself.","tags":["java","java-upgrade"],"inputSchema":{"type":"object","properties":{"originalPrompt":{"type":"string","description":"The original user prompt describing the upgrade request to pass to the custom agent. Pass the prompt as-is, except you MUST remove any reference to this tool itself from the prompt text, such as 'using #appmod-generate-upgrade-plan', '#appmod-generate-upgrade-plan', 'using #appmod-redirect-to-upgrade-agent', or '#appmod-redirect-to-upgrade-agent'."},"projectPath":{"type":"string","description":"The absolute path to the Java project to upgrade."}}}},{"name":"appmod-confirm-upgrade-plan","displayName":"Review Plan","userDescription":"Review the generated plan for upgrading the Java project","icon":"assets/JavaUpgrade_16x.svg","toolReferenceName":"appmod-confirm-upgrade-plan","canBeReferencedInPrompt":true,"when":"appmod.hasJavaProjectInWorkspace","modelDescription":"This tool present the generated plan to the user, allowing users to make adjustments to the plan and confirm before execution. You should invoke this tool after the plan is generated to ask user to confirm. This tool should only be invoked during an upgrade process.","tags":["java","java-upgrade"],"inputSchema":{"type":"object","properties":{"sessionId":{"type":"string","description":"The id of the upgrade session during which this tool is invoked. You MUST NEVER generate a sessionId by yourself; you must use a user-provided sessionId or one generated by a tool, leave it empty otherwise."}},"required":["sessionId"]}},{"name":"appmod-validate-cves-for-java","displayName":"Check CVEs","userDescription":"Check if the given Java dependencies have any known CVEs","icon":"assets/JavaUpgrade_16x.svg","toolReferenceName":"appmod-validate-cves-for-java","canBeReferencedInPrompt":true,"when":"appmod.hasJavaProjectInWorkspace","modelDescription":"This tools checks if the given Java dependencies have any known vulnerabilities (CVEs). It will return a list of CVE issues found in the given dependencies, along with their severity and description. You MUST pass the dependencies to check as input, be careful that each dependency MUST be in the format of `groupId:artifactId:version`, e.g. `org.apache.commons:commons-lang3:3.12.0`. You must filter out any dependencies if you can not determine the version of them. You should use this tool to check for any known CVEs in the dependencies of the Java project","tags":["java"],"inputSchema":{"type":"object","properties":{"sessionId":{"type":"string","description":"The id of the upgrade session during which this tool is invoked. You MUST NEVER generate a sessionId by yourself; you must use a user-provided sessionId or one generated by a tool, leave it empty otherwise."},"projectPath":{"type":"string","description":"The absolute path to the Java project whose dependencies are to be checked for CVEs."},"dependencies":{"type":"array","description":"An array of Java dependencies to check for CVE issues. Each dependency should be in the format of `groupId:artifactId:version` (all the 3 parts, groupId, artifactId and version are required), e.g. `org.apache.commons:commons-lang3:3.12.0`. Filter out any dependencies if you can not determine the version of them.","items":{"type":"string","description":"dependency (in the format of `groupId:artifactId:version`, all the 3 parts, groupId, artifactId and version are required, e.g. `org.apache.commons:commons-lang3:3.12.0`) to check for CVE issues."}}},"required":["dependencies"]}},{"name":"appmod-generate-tests-for-java","displayName":"Generate Unit Tests","userDescription":"Generate unit test cases for the Java project using LLM","icon":"assets/JavaUpgrade_16x.svg","toolReferenceName":"appmod-generate-tests-for-java","canBeReferencedInPrompt":true,"when":"appmod.hasJavaProjectInWorkspace","modelDescription":"This tool generates test cases for the Java classes of a Java project. This tool will iterate through all the Java classes in the project and generate test cases for each class, so it would be time consuming for large projects.","tags":["java","java-upgrade"],"inputSchema":{"type":"object","properties":{"sessionId":{"type":"string","description":"The id of the test generation session during which this tool is invoked. You MUST NEVER generate a sessionId by yourself; you must use a user-provided sessionId or one generated by a tool, leave it empty otherwise."},"projectPath":{"type":"string","description":"The absolute path to the Java project to generate test cases. This should be the root directory containing the project's build files."},"jdkPath":{"type":"string","description":"The absolute path to the JDK installation, which matches the project's current Java version. This tool will try to detect a JDK installed on the system if not specified"},"buildToolPath":{"type":"string","description":"The absolute path to the build tool (e.g., Maven, Gradle) installation for the project specified by 'projectPath'. This tool will try to detect a build tool installed on the system if not specified"}}}},{"name":"appmod-build-java-project","displayName":"Build Project","userDescription":"Build Java project to check status","icon":"assets/JavaUpgrade_16x.svg","toolReferenceName":"appmod-build-java-project","canBeReferencedInPrompt":true,"when":"appmod.hasJavaProjectInWorkspace","modelDescription":"This tool uses Maven or Gradle to build Java project and report any build errors. This tool detects the build tool and JDK smartly. You can use this tool to check the build status of the project after making changes to the code or dependencies. You MUST only call this tool when it is explicitly referenced in the prompt.","tags":["java"],"inputSchema":{"type":"object","properties":{"sessionId":{"type":"string","description":"The id of the upgrade session during which this tool is invoked. You MUST NEVER generate a sessionId by yourself; you must use a user-provided sessionId or one generated by a tool, leave it empty otherwise."},"projectPath":{"type":"string","description":"The absolute path to the Java project to build. This should be the root directory containing the project's build files."},"jdkPath":{"type":"string","description":"The absolute path to the JDK installation, which matches the project's current Java version. This tool will try to detect a JDK installed on the system if not specified"},"buildToolPath":{"type":"string","description":"The absolute path to the build tool (e.g., Maven, Gradle) installation for the project specified by 'projectPath'. This tool will try to detect a build tool installed on the system if not specified"}},"required":["projectPath"]}},{"name":"appmod-run-tests-for-java","displayName":"Run Unit Tests","userDescription":"Run tests in the Java project using the build tool","icon":"assets/JavaUpgrade_16x.svg","toolReferenceName":"appmod-run-tests-for-java","canBeReferencedInPrompt":true,"when":"appmod.hasJavaProjectInWorkspace","modelDescription":"This tool runs test cases in the Java project using the build tool (e.g. Maven, Gradle) and reports any test errors/failures. This tool can be used to check the test status of the project. You MUST only call this tool when it is explicitly referenced in the prompt.","tags":["java"],"inputSchema":{"type":"object","properties":{"sessionId":{"type":"string","description":"The id of the upgrade session during which this tool is invoked. You MUST NEVER generate a sessionId by yourself; you must use a user-provided sessionId or one generated by a tool, leave it empty otherwise."},"projectPath":{"type":"string","description":"The absolute path to the Java project to run tests. This should be the root directory containing the project's build files."},"jdkPath":{"type":"string","description":"The absolute path to the JDK installation, which matches the project's current Java version. This tool will try to detect a JDK installed on the system if not specified"},"buildToolPath":{"type":"string","description":"The absolute path to the build tool (e.g., Maven, Gradle) installation for the project specified by 'projectPath'. This tool will try to detect a build tool installed on the system if not specified"}},"required":["projectPath"]}},{"name":"appmod-list-jdks","displayName":"List JDKs","userDescription":"List all available JDKs on the system","icon":"assets/JavaUpgrade_16x.svg","toolReferenceName":"appmod-list-jdks","canBeReferencedInPrompt":true,"modelDescription":"This tool lists available JDKs (Java Development Kits) on the system. It can be used to find installed JDKs path and version. The result will be in json format","tags":["java","jdk"],"inputSchema":{"type":"object","properties":{"sessionId":{"type":"string","description":"The id of the upgrade session during which this tool is invoked. You MUST NEVER generate a sessionId by yourself; you must use a user-provided sessionId or one generated by a tool, leave it empty otherwise."},"additionalSearchPaths":{"type":"array","description":"An array of paths to search for JDK installations.","items":{"type":"string","description":"A path to search for JDK installations."}},"version":{"type":"string","description":"The major version of JDK to search. If not specified, all versions will be listed."}}}},{"name":"appmod-list-mavens","displayName":"List Mavens","userDescription":"List all available Mavens on the system","icon":"assets/JavaUpgrade_16x.svg","toolReferenceName":"appmod-list-mavens","canBeReferencedInPrompt":true,"modelDescription":"This tool lists all available Mavens (Apache Maven) on the system. It can be used to find installed Mavens path and version. The result will be in json format","tags":["java","maven"],"inputSchema":{"type":"object","properties":{"sessionId":{"type":"string","description":"The id of the upgrade session during which this tool is invoked. You MUST NEVER generate a sessionId by yourself; you must use a user-provided sessionId or one generated by a tool, leave it empty otherwise."},"additionalSearchPaths":{"type":"array","description":"An array of paths to search for Maven installations.","items":{"type":"string","description":"A path to search for Maven installations."}},"includeVersion":{"type":"boolean","default":false,"description":"Whether to include the version of Maven in the search, by default will be false. When set to true, it may take longer time."}}}},{"name":"appmod-install-jdk","displayName":"Install JDK","userDescription":"Install a specific version of JDK from the internet","icon":"assets/JavaUpgrade_16x.svg","toolReferenceName":"appmod-install-jdk","canBeReferencedInPrompt":true,"modelDescription":"This tool installs a specific version of JDK from the internet. It downloads and installs the JDK from a trusted source (Microsoft/Eclipse Adoptium) and returns the installation path. This tool can be used when you need to install a JDK for a Java project or when the required JDK version is not available on the system.","tags":["java","jdk","install"],"inputSchema":{"type":"object","properties":{"sessionId":{"type":"string","description":"The id of the upgrade session during which this tool is invoked. You MUST NEVER generate a sessionId by yourself; you must use a user-provided sessionId or one generated by a tool, leave it empty otherwise."},"version":{"type":"string","description":"The version of JDK to install, if not set, the latest LTS version will be installed."},"dest":{"type":"string","description":"The absolute path to the directory where the JDK will be installed. If not provided, ~/.jdk will be used."}},"required":["version"]}},{"name":"appmod-install-maven","displayName":"Install Maven","userDescription":"Install a specific version of Maven from the internet","icon":"assets/JavaUpgrade_16x.svg","toolReferenceName":"appmod-install-maven","canBeReferencedInPrompt":true,"modelDescription":"This tool installs a specific version of Maven from the internet. It downloads and installs Maven from a trusted source and returns the installation path. This tool can be used when you need to install Maven for a Java project or when the required Maven version is not available on the system.","tags":["java","maven","install"],"inputSchema":{"type":"object","properties":{"sessionId":{"type":"string","description":"The id of the upgrade session during which this tool is invoked. You MUST NEVER generate a sessionId by yourself; you must use a user-provided sessionId or one generated by a tool, leave it empty otherwise."},"version":{"type":"string","default":"latest","enum":["latest","3.9.11","3.8.9"],"description":"The version of Maven to install, supported values are 'latest', '3.9.11' and '3.8.9'"},"dest":{"type":"string","description":"The absolute path to the directory where Maven will be installed. If not provided, ~/.maven will be used."}},"required":["version"]}},{"name":"appmod-report-event","displayName":"Report Event","userDescription":"Report an upgrade event for telemetry tracking","icon":"assets/JavaUpgrade_16x.svg","toolReferenceName":"appmod-report-event","canBeReferencedInPrompt":true,"modelDescription":"This tool reports upgrade events for telemetry and progress tracking. Use this tool to report important milestones during the Java upgrade process such as precheck completion, plan generation, build/test results, step execution, and final summary.","tags":["java","telemetry","event"],"inputSchema":{"type":"object","properties":{"sessionId":{"type":"string","description":"The id of the upgrade session during which this tool is invoked. You MUST NEVER generate a sessionId by yourself. It MUST be empty when `event` is `precheckCompleted` or `securityTaskStarted`, and MUST be the session id generated by that event for all other events."},"projectPath":{"type":"string","description":"The absolute path to the Java project being upgraded."},"event":{"type":"string","enum":["precheckCompleted","planGenerationStarted","planReviewed","planConfirmed","planExecutionStarted","environmentSetup","baselineSetup","upgradeStepStarted","buildCompleted","testCompleted","upgradeStepCompleted","upgradeValidationCompleted","planExecutionCompleted","summaryGenerated","securityTaskStarted","securityPlanReviewed","securityBuildCompleted","securityFixCompleted"],"description":"The event name identifying the upgrade milestone."},"status":{"type":"string","enum":["succeeded","failed","skipped"],"description":"The status of the event."},"phase":{"type":"string","enum":["precheck","plan","execute","summarize"],"description":"The phase of the upgrade process."},"details":{"type":"object","description":"Optional event-specific key-value pairs.","additionalProperties":{"type":["string","number","boolean"]}},"message":{"type":"string","description":"Optional human-readable description of the event."}},"required":["projectPath","event","phase","status"]}},{"name":"appmod_analyze_repository","tags":["appmod","codetocloud"],"displayName":"@appmod analyze repository","modelDescription":"Analyzes a repository to detect programming languages, frameworks, dependencies, and build systems. This should be the FIRST tool used when containerizing an application. Returns detailed module information including:\n- Detected languages and versions (Node.js, Python, Go, Java, etc.)\n- Frameworks (Express, FastAPI, Spring Boot, etc.)\n- Package managers and dependency files\n- Build systems and entry points\n- Monorepo structure (if applicable)\n\nUse the analysis results to inform Dockerfile generation. This is a read-only operation that only examines file contents.","inputSchema":{"type":"object","properties":{"repositoryPath":{"type":"string","minLength":1,"description":"Absolute path to the repository. Paths are automatically normalized to forward slashes on all platforms (e.g., /path/to/repo or C:/path/to/repo)"},"depth":{"type":"number","description":"Analysis depth (1-5)"},"includeTests":{"type":"boolean","description":"Include test files in analysis"},"securityFocus":{"type":"boolean","description":"Focus on security aspects"},"performanceFocus":{"type":"boolean","description":"Focus on performance aspects"},"modules":{"type":"array","items":{"type":"object","properties":{"name":{"type":"string","description":"The name of the module"},"modulePath":{"type":"string","description":"Absolute path to module root. Paths are automatically normalized to forward slashes on all platforms."},"dockerfilePath":{"type":"string","description":"Path where the Dockerfile should be generated"},"language":{"type":"string","enum":["java","dotnet","javascript","typescript","python","rust","go","other"],"description":"Primary programming language used in the module"},"frameworks":{"type":"array","items":{"type":"object","properties":{"name":{"type":"string","description":"Frameworks used in project like Java Spring, SpringBoot, Hibernate etc."},"version":{"type":"string"}},"required":["name"]}},"buildSystems":{"type":"array","items":{"type":"object","properties":{"type":{"type":"string"},"languageVersion":{"type":"string"}},"required":["type"]},"description":"All detected build systems with their language versions"},"dependencies":{"type":"array","items":{"type":"string"},"description":"List of module dependencies including database drivers and system libraries"},"ports":{"type":"array","items":{"type":"number"}},"entryPoint":{"type":"string"}},"required":["name","modulePath"]},"description":"Optional pre-analyzed modules. If not provided, AI will analyze the repository."}},"required":["repositoryPath"],"$schema":"http://json-schema.org/draft-07/schema#"},"toolReferenceName":"appmod_analyze_repository","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true"},{"name":"appmod_check_quota","tags":["appmod","codetocloud"],"displayName":"@appmod check Azure quota","modelDescription":"This tool will check the Azure quota availability for the resources that are going to be deployed.","inputSchema":{"type":"object","properties":{"subscriptionId":{"type":"string","description":"The Azure subscription ID where the resources will be deployed. Retrieve the subscription ID from the context, or by prompting the user to provide it."},"region":{"type":"string","description":"The valid Azure region where the resources will be deployed. E.g. 'eastus2', 'westus', 'westeurope', etc."},"resourceTypes":{"type":"array","items":{"type":"string"},"description":"The valid Azure resource types that are going to be deployed. E.g. 'Microsoft.App/containerApps', 'Microsoft.Web/sites', 'Microsoft.CognitiveServices/accounts', etc, or 'appservicemanagedinstance' ONLY if App Service Managed Instance is used."},"workspaceFolder":{"type":"string","description":"The full path of the workspace folder. Use '/' as path separator."}},"required":["subscriptionId","region","resourceTypes","workspaceFolder"]},"toolReferenceName":"appmod_check_quota","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true"},{"name":"appmod_diagnostic_existing_resources","tags":["appmod","codetocloud"],"displayName":"@appmod diagnose existing resources","modelDescription":"This tool analyzes existing Azure resources to diagnose their configurations and connections, and provides recommendations to prevent application deployment failures. Use this tool when the user has Azure existing resources and wants to deploy new applications that depend on those resources. Note it can only diagnose configuration of Container Apps and AKS to access ACR.","inputSchema":{"type":"object","properties":{"containerRegistryConnections":{"type":"object","properties":{"containerRegistryId":{"type":"string","description":"ID of the existing Azure Container Registry resource. Format: /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.ContainerRegistry/registries/{registryName}"},"containerAppIds":{"type":"array","items":{"type":"string"},"description":"List of existing Azure Container App resource IDs which should access the Container Registry. Format: /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.App/containerApps/{containerAppName}"},"kubernetesIds":{"type":"array","items":{"type":"string"},"description":"List of existing Azure Kubernetes Service resource IDs which should access the Container Registry. Format: /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.ContainerService/managedClusters/{clusterName}"}},"required":["containerRegistryId","containerAppIds","kubernetesIds"],"description":"Container Registry configuration with associated container apps or Kubernetes services."},"keyVaultConnections":{"type":"object","properties":{"keyVaultId":{"type":"string","description":"ID of the existing Azure Key Vault resource. Format: /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.KeyVault/vaults/{vaultName}"},"containerAppIds":{"type":"array","items":{"type":"string"},"description":"List of existing Azure Container App resource IDs which should access the Key Vault. Format: /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.App/containerApps/{containerAppName}"},"kubernetesIds":{"type":"array","items":{"type":"string"},"description":"List of existing Azure Kubernetes Service resource IDs which should access the Key Vault. Format: /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.ContainerService/managedClusters/{clusterName}"}},"required":["keyVaultId","containerAppIds","kubernetesIds"],"description":"Key Vault configuration with associated container apps or Kubernetes services."}}},"toolReferenceName":"appmod_diagnostic_existing_resources","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true"},{"name":"appmod_generate_architecture_diagram","tags":["appmod","codetocloud"],"displayName":"@appmod generate architecture diagram","modelDescription":"Generates an azure service architecture diagram for the application. Call this tool when the user needs design or display of the azure architecture of their application. Before calling this tool, please scan this workspace to detect the services to deploy and their dependent services. If user uses existing resources for deployment, try to match the service type and names to the existing infrastructure. Try your best to fulfill the input schema with your analyze result.","inputSchema":{"type":"object","properties":{"workspaceFolder":{"type":"string","description":"The full path of the workspace folder. Use '/' as path separator."},"projectName":{"type":"string","description":"The name of the project."},"services":{"type":"array","items":{"type":"object","properties":{"name":{"type":"string","description":"The name of the service."},"path":{"type":"string","description":"The absolute path of the service folder. This folder should contain an entrypoint file such as main.py, index.js, Program.cs, App.java, etc. Use '/' as path separator."},"language":{"type":"string","enum":["dotnet","python","js","ts","java"],"description":"The programming language of the service."},"port":{"type":"string","description":"The port number the service uses. Get this from Dockerfile or Kubernetes manifest. If not available, default to '80'."},"azureComputeHost":{"type":"string","enum":["appservice","appservicemanagedinstance","containerapp","functionapp","aks"],"description":"The azure service to host this service. Keep consistent with plan tool."},"dockerSettings":{"type":"object","properties":{"dockerFilePath":{"type":"string","description":"The absolute path to the Dockerfile for the service. Leave blank if the service is not containerized or Dockerfile is not yet created. Use '/' as path separator."},"dockerContext":{"type":"string","description":"The absolute path to the Docker build context for the service. Leave blank if the service is not containerized or Docker build context is not yet created. Use '/' as path separator."}},"required":["dockerFilePath","dockerContext"],"description":"Docker settings for the service. Leave blank if the service is not containerized or Docker settings are not yet created."},"dependencies":{"type":"array","items":{"type":"object","properties":{"name":{"type":"string","description":"The name of the dependent service. Can be arbitary, or must reference another service in the services array if referencing azureappservice, azurecontainerapp, or azurefunctions. If existing azure resources are provided, try to match the dependency name to the existing resource name with the same type."},"serviceType":{"type":"string","enum":["azureaisearch","azureaiservices","appservice","appservicemanagedinstance","azureapplicationinsights","azurebotservice","containerapp","azurecosmosdb","function","azurekeyvault","aks","azuredatabaseformysql","azureopenai","azuredatabaseforpostgresql","azureprivateendpoint","azurecacheforredis","azuresqldatabase","azurestorageaccount","staticwebapp","azureservicebus","azuresignalrservice","azurevirtualnetwork","azurewebpubsub","azurecontainerregistry"],"description":"The type of the azure service that can be used for this dependent service. If existing azure resources are provided, only fill in the serviceType that represents the existing resource type."},"connectionType":{"type":"string","enum":["secret","system-identity","user-identity","http","bot-connection"],"description":"The connection authentication type of the dependency."}},"required":["name","serviceType","connectionType"]},"description":"An array of dependent services. A compute service may have a dependency on another compute service."}},"required":["name","path","language","port","azureComputeHost","dependencies"]},"description":"An array of services. Each service is a separately deployed compute service. A service can be a container app, aks, web app, function app, etc. Each service can have dependencies."}},"required":["workspaceFolder","projectName","services"]},"toolReferenceName":"appmod_generate_architecture_diagram","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true"},{"name":"appmod_get_app_logs","tags":["appmod","codetocloud"],"displayName":"@appmod get app logs","modelDescription":"This tool helps fetch logs from log analytics workspace for Container Apps, App Services, function apps that were deployed. Invoke this tool directly after a successful deployment with commands like `azd up` `az containerapp create`, `az webapp deploy`, or `az functionapp deployment source config-zip`, or when user prompts to check the app's status or provide errors in the deployed apps.","inputSchema":{"type":"object","properties":{"workspaceFolder":{"type":"string","description":"The full path of the workspace folder. Use '/' as path separator."},"subscriptionId":{"type":"string","description":"The Azure subscription ID (AZURE_SUBSCRIPTION_ID). If not provided in context, try to find it in the .azure/**/env file."},"limit":{"description":"The maximum number of log rows to retrieve. Default is 200.","type":"number","minimum":1},"resourceGroupName":{"type":"string","description":"The name of the Azure resource group where the resources are deployed. Used as the '--resource-group' argument in azcli commands (e.g. 'az webapp log tail --resource-group <name>', 'az containerapp logs show --resource-group <name>'). If not provided in context, try to find it in the project's IaC files (e.g. Bicep, ARM, Terraform) or ask the user."},"resources":{"type":"array","items":{"type":"object","properties":{"name":{"type":"string","description":"The Azure resource name (the 'name' property, i.e., the last segment of the resource ID path)."},"type":{"type":"string","enum":["containerapp","appservice","functionapp"],"description":"Resource type. Use exactly one of: 'containerapp', 'appservice', 'functionapp'. Do NOT use ARM-style types like 'Microsoft.App/containerApps'."}},"required":["name","type"]},"description":"List of Azure resources to query logs for. Each entry must have 'name' (resource name) and 'type'. Example: [{\"name\": \"myapp\", \"type\": \"containerapp\"}]"}},"required":["workspaceFolder","subscriptionId","resourceGroupName","resources"]},"toolReferenceName":"appmod_get_app_logs","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true"},{"name":"appmod_get_available_region","tags":["appmod","codetocloud"],"displayName":"@appmod check region availability","modelDescription":"Given a list of Azure resource types, this tool will return a list of regions where the resource types are available. Always get the user's subscription ID before calling this tool.","inputSchema":{"type":"object","properties":{"subscriptionId":{"type":"string","description":"The user's Azure subscription ID (in GUID format). Retrieve the subscription ID from the context, or by prompting the user to provide it."},"resourceTypes":{"type":"array","items":{"type":"string"},"description":"The valid Azure resource types. E.g. 'Microsoft.App/containerApps', 'Microsoft.Web/sites', 'Microsoft.CognitiveServices/accounts', etc, or 'appservicemanagedinstance' ONLY if App Service Managed Instance is used."},"cognitiveServiceProperties":{"type":"object","properties":{"modelName":{"description":"The name of the model.","type":"string"},"modelVersion":{"description":"The version of the model.","type":"string"},"deploymentSkuName":{"description":"The SKU name of the model deployment.","type":"string","enum":["GlobalStandard","GlobalProvisionedManaged","GlobalBatch","DataZoneStandard","DataZoneProvisionedManaged","DataZoneBatch","ProvisionedManaged","Standard"]}},"description":"Optional configuration for model-specific checks. This is only needed when Microsoft.CognitiveServices is included in resourceTypes above."},"workspaceFolder":{"type":"string","description":"The full path of the workspace folder. Use '/' as path separator."}},"required":["subscriptionId","resourceTypes","workspaceFolder"]},"toolReferenceName":"appmod_get_available_region","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true"},{"name":"appmod_get_available_region_sku","tags":["appmod","codetocloud"],"displayName":"@appmod get available regions and SKUs for deployment","modelDescription":"This tool will give a list of available regions and SKUs which support deployment. If you meet any region or quota issues during deployment, call this tool to get information.","inputSchema":{"type":"object","properties":{"subscriptionId":{"type":"string","description":"The user's Azure subscription ID (in GUID format). DO NOT FORCE an azure login to use azcli context."},"preferredRegions":{"type":"array","items":{"type":"string"},"description":"The regions where user prefers to deploy, e.g. eastus2, australiaeast. If no specific preference, leave it blank"},"resourceTypes":{"type":"array","items":{"type":"object","properties":{"type":{"type":"string","description":"The valid Azure resource types. E.g. 'Microsoft.App/containerApps', 'Microsoft.Web/sites', 'Microsoft.CognitiveServices/accounts', etc, or 'appservicemanagedinstance' ONLY if App Service Managed Instance is used."},"quota":{"default":1,"description":"The quota required for the resource type. Default to 1.","type":"number","minimum":1}},"required":["type","quota"]},"description":"The valid Azure resource types and quota each resource needs."},"cognitiveServiceProperties":{"type":"object","properties":{"modelName":{"description":"The name of the model.","type":"string"},"modelVersion":{"description":"The version of the model.","type":"string"},"deploymentSkuName":{"description":"The SKU name of the model deployment.","type":"string","enum":["GlobalStandard","GlobalProvisionedManaged","GlobalBatch","DataZoneStandard","DataZoneProvisionedManaged","DataZoneBatch","ProvisionedManaged","Standard"]}},"description":"Optional configuration for model-specific checks. This is only needed when Microsoft.CognitiveServices is included in resourceTypes above."},"workspaceFolder":{"type":"string","description":"The full path of the workspace folder. Use '/' as path separator."}},"required":["resourceTypes","workspaceFolder"]},"toolReferenceName":"appmod_get_available_region_sku","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true"},{"name":"appmod_get_azure_landing_zone_plan","tags":["appmod","codetocloud"],"displayName":"@appmod get ALZ plan","modelDescription":"Entry point to generate an IaC plan for a customized Azure Application Landing Zone. Use it to create tailored Azure Landing Zones that adhere to best practices and organizational standards.","inputSchema":{"type":"object","properties":{"iacType":{"type":"string","enum":["bicep","terraform"],"description":"The type of IaC files to generate for the customized Azure Landing Zone. Default to Bicep if not specified."}},"required":["iacType"]},"toolReferenceName":"appmod_get_azure_landing_zone_plan","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true"},{"name":"appmod_get_cicd_pipeline_guidance","tags":["appmod","codetocloud"],"displayName":"@appmod get CICD pipeline guidance","modelDescription":"This tool helps create a CI/CD pipeline to deploy a project to Azure. BEFORE calling this tool, you MUST confirm with user 1. if they want to use Github Actions/ADO pipeline/GitLab CICD 2. if they have existing Azure resources to deploy for different environments. If user has existing Azure resources, *ASK* for subscription ID, resource groups, environments, Azure hosting service TYPEs. If user does not have existing resources, *ASK* whether to include provision in the pipeline. *DO NOT call this tool UNTIL you made these confirmations with user*.","inputSchema":{"type":"object","properties":{"isAZDProject":{"type":"boolean","description":"Whether to use azd tool in the deployment pipeline. Set to true ONLY if azure.yaml is provided or the context suggests AZD tools, using AZCLI by default."},"pipelinePlatform":{"type":"string","enum":["GitHub Actions","Azure DevOps","GitLab CI/CD"],"description":"The platform for the deployment pipeline."},"deployOption":{"description":"Default to deploy-only. Set to 'provision-and-deploy' ONLY WHEN user explicitly wants infra provisioning pipeline using local provisioning scripts.","type":"string","enum":["deploy-only","provision-only","provision-and-deploy"]},"subscriptionId":{"description":"The Azure subscription ID to deploy to.","type":"string"},"workspaceFolder":{"type":"string","description":"The full path of the workspace folder. Use '/' as path separator."}},"required":["isAZDProject","pipelinePlatform","workspaceFolder"]},"toolReferenceName":"appmod_get_cicd_pipeline_guidance","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true"},{"name":"appmod_get_containerization_plan","tags":["appmod","codetocloud"],"displayName":"@appmod get containerization plan","modelDescription":"Entry point to help the agent generate a containerization plan for the application. Agent should read its output and generate a containerization plan in '.azure/containerization.copilotmd' for execution steps, and steps needed to convert the projects to container-ready with Dockerfile. Before calling this tool, please scan this workspace to detect the services to containerize.","inputSchema":{"type":"object","properties":{"workspaceFolder":{"type":"string","description":"The workspace folder of the current project. Use '/' as path separator."},"servicePaths":{"type":"array","items":{"type":"string"},"description":"The absolute paths of each service to deploy. Each service is a separately deployed compute service. Use '/' as path separator."},"existingContainerRegistryResourceId":{"type":"string","description":"The existing container registry to perform remote docker builds. Leave blank if not available."}},"required":["workspaceFolder","servicePaths"]},"toolReferenceName":"appmod_get_containerization_plan","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true"},{"name":"appmod_get_iac_rules","tags":["appmod","codetocloud"],"displayName":"@appmod get IaC rules","modelDescription":"This tool offers guidelines for creating Bicep/Terraform files to deploy applications on Azure as well as general Azure Resource Rules. The guidelines outline rules to improve the quality of Infrastructure as Code files and resource configurations, ensuring they are compatible with the azd tool or az cli and adhere to best practices.","inputSchema":{"type":"object","properties":{"deploymentTool":{"type":"string","enum":["azd","azcli"],"description":"Deployment tool used. Can be 'azd' or 'azcli'. 'azcli' is recommended."},"iacType":{"anyOf":[{"type":"string","enum":["bicep","terraform"]},{"type":"string","const":""}],"description":"The type of IaC file used for deployment. Keep consistent with get-plan tool input. Leave empty if user wants to use azcli command script."},"resourceTypes":{"type":"array","items":{"type":"string"},"description":"List of Azure resource types to generate rules for. Get the value from context and use the same resources defined in plan. Valid value: appservice,appservicemanagedinstance,containerapp,function,aks,azuredatabaseforpostgresql,azuredatabaseformysql,azuresqldatabase,azurecosmosdb,azurestorageaccount,azurekeyvault,azurecontainerregistry"},"workspaceFolder":{"type":"string","description":"The full path of the workspace folder. Use '/' as path separator."}},"required":["deploymentTool","resourceTypes","workspaceFolder"]},"toolReferenceName":"appmod_get_iac_rules","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true"},{"name":"appmod_get_plan","tags":["appmod","codetocloud"],"displayName":"@appmod get plan","modelDescription":"Entry point to help the agent deploy a service to the cloud. Agent should read its output and generate a deploy plan in '.azure/plan.copilotmd' for execution steps, recommended Azure services based on the information agent detected from project. Before calling this tool, scan this workspace to detect the services to deploy and their dependent services. If user has existing resources and only wants to deploy to existing resources, agent MUST first ask user to provide EXISTING Azure resources' ARM IDs or pick the IDs if user wants to use Az CLI command! Do NOT run az login before calling this tool, even if terminal shows login errors.","inputSchema":{"type":"object","properties":{"workspaceFolder":{"type":"string","description":"The full path of the workspace folder. Use '/' as path separator."},"projectName":{"type":"string","description":"The name of the project to generate the deployment plan for. If not provided, will be inferred from the workspace."},"services":{"type":"array","items":{"type":"object","properties":{"name":{"type":"string","description":"The name of the service."},"path":{"type":"string","description":"The absolute path of the service folder. This folder should contain an entrypoint file such as main.py, index.js, Program.cs, App.java, etc. Use '/' as path separator."},"language":{"type":"string","enum":["dotnet","python","js","ts","java"],"description":"The programming language of the service."},"azureComputeHost":{"type":"string","enum":["appservice","appservicemanagedinstance","containerapp","functionapp","aks"],"description":"The compute host Azure resource type for the service. If the project is written in .NET framework, use AzureAppServiceManagedInstance as default."},"dependencies":{"type":"array","items":{"type":"object","properties":{"name":{"type":"string","description":"The name of the dependent service. Can be arbitrary, or must reference another service in the services array if referencing azureappservice, azurecontainerapp, or azurefunctions. If existing azure resources are provided, try to match the dependency name to the existing resource name with the same type."},"serviceType":{"type":"string","enum":["azureaisearch","azureaiservices","appservice","appservicemanagedinstance","azureapplicationinsights","azurebotservice","containerapp","azurecosmosdb","function","azurekeyvault","aks","azuredatabaseformysql","azureopenai","azuredatabaseforpostgresql","azureprivateendpoint","azurecacheforredis","azuresqldatabase","azurestorageaccount","staticwebapp","azureservicebus","azuresignalrservice","azurevirtualnetwork","azurewebpubsub","azurecontainerregistry"],"description":"The type of the azure service that can be used for this dependent service. If existing azure resources are provided, only fill in the serviceType that represents the existing resource type."},"connectionType":{"type":"string","enum":["secret","system-identity","user-identity","http","bot-connection"],"description":"The connection authentication type of the dependency. Infer this from the user application."}},"required":["name","serviceType","connectionType"]},"description":"An array of dependent services. A compute service may have a dependency on another compute service."}},"required":["name","path","language","azureComputeHost","dependencies"]},"description":"The list of services in the project. Each service is a separately deployed compute service."},"languages":{"type":"array","items":{"type":"string","enum":["dotnet","python","js","ts","java"]},"description":"The list of programming languages used in the project for each service."},"provisioningTool":{"type":"string","enum":["azd","azcli"],"description":"The tool to use for provisioning Azure resources. Use azcli by default unless the context suggests using azd."},"iacOptions":{"anyOf":[{"type":"string","enum":["bicep","terraform"]},{"type":"string","const":""}],"description":"The Infrastructure as Code option. Leave empty if user wants to use azcli command script."},"sourceType":{"type":"string","enum":["from-project","from-azure","from-context"],"description":"The source of the plan to generate from. If user doesn't have existing resources, set 'from-project' and generating deploy plan based on the project files in the workspace. If user mentions Azure resources exist, set 'from-azure' and ask for existing Azure resources details to generate plan. If the user have no existing resource but declare the expected Azure resources, use 'from-context' and the deploy plan should be based on the user's input."},"deployOption":{"type":"string","enum":["deploy-only","provision-only","provision-and-deploy"],"description":"Set the value based on project and user's input. Use 'deploy-only' if user mentions they want to deploy to existing Azure resources or Iac files already exist in project, get Azure resource group from project files or from user. Use 'provision-only' if user only wants to provision Azure resource. Use 'provision-and-deploy' if user wants to deploy application and doesn't have existing infrastructure resources, or are starting from an empty resource group."},"subscriptionId":{"type":"string","description":"The Azure subscription ID to use for the deployment. Prompt the user to provide. Leave this empty if agent is not sure."},"resourceGroupName":{"type":"string","description":"The Azure resource group name to use for the deployment. If user has existing resources and is deploying to existing resources, agent must use existing resource's resource group, ask for user's confirmation before using its resource group name."}},"required":["workspaceFolder","projectName","services","languages","provisioningTool","sourceType","deployOption"]},"toolReferenceName":"appmod_get_plan","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true"},{"name":"appmod_get_waf_rules","tags":["appmod","codetocloud"],"displayName":"@appmod get WAF rules","modelDescription":"This tool provides Azure Well-Architected Framework (WAF) rules for Azure resources in Azure Application Landing Zone, ensuring secure, compliant, and production-ready configurations.","inputSchema":{"type":"object","properties":{"resourceTypes":{"type":"array","items":{"type":"string","enum":["api-management","app-service","application-gateway","application-insights","azure-blob-storage","azure-databricks","azure-disk-storage","azure-express-route","azure-files","azure-firewall","azure-iot-hub","azure-kubernetes-service","azure-log-analytics","azure-machine-learning","azure-netapp-files","azure-service-fabric","azure-sql-managed-instance","azure-traffic-manager","container-apps","cosmos-db","event-grid","event-hubs","front-door","function-apps","key-vault","load-balancer","mysql-database","postgresql","service-bus","sql-database","storage-accounts","virtual-machines","virtual-networks"]},"description":"The types of Azure resources to get WAF rules for."}},"required":["resourceTypes"]},"toolReferenceName":"appmod_get_waf_rules","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true"},{"name":"appmod_plan_generate_dockerfile","tags":["appmod","codetocloud"],"displayName":"@appmod generate Dockerfile","modelDescription":"Generates an optimized Dockerfile plan for a repository. Use AFTER analyze_repo to have context about the application. Returns a structured plan including:\n- Recommended base images with security rationale\n- Multi-stage build strategy\n- Dependency installation commands\n- Build and runtime configurations\n- Security best practices (non-root user, minimal attack surface)\n- Health check recommendations\n\nThe plan is returned as structured data, NOT the actual Dockerfile content. The LLM should use this plan to write the final Dockerfile.","inputSchema":{"type":"object","properties":{"repositoryPath":{"type":"string","minLength":1,"description":"Repository path (automatically normalized to forward slashes on all platforms)."},"modulePath":{"type":"string","description":"Module path for monorepo/multi-module projects to locate where the Dockerfile should be generated (automatically normalized to forward slashes)."},"language":{"type":"string","description":"Primary programming language (e.g., \"java\", \"python\")"},"languageVersion":{"type":"string","description":"Language version (e.g., \"17\", \"3.11\", \"20\"). For Java, this is the java.version from pom.xml or sourceCompatibility from build.gradle."},"framework":{"type":"string","description":"Framework used (e.g., \"spring\", \"django\")"},"environment":{"type":"string","enum":["development","staging","production","testing"],"description":"Target environment (production, development, etc.)"},"detectedDependencies":{"type":"array","items":{"type":"string"},"description":"Detected libraries/frameworks/features from repository analysis (e.g., [\"redis\", \"ef-core\", \"signalr\", \"mongodb\", \"health-checks\"]). This helps match relevant knowledge entries."},"targetPlatform":{"type":"string","enum":["linux/amd64","linux/arm64","linux/arm/v7","linux/arm/v6","linux/386","linux/ppc64le","linux/s390x","linux/riscv64","windows/amd64"],"default":"linux/amd64","description":"Target platform for the Docker image (e.g., \"linux/amd64\", \"linux/arm64\"). Defaults to linux/amd64 for maximum compatibility. Use this to cross-compile for different architectures (e.g., ARM Mac targeting AMD64 servers)."},"trafficLevel":{"type":"string","enum":["high","medium","low"],"description":"Expected traffic level for dynamic defaults calculation (affects replica counts and scaling)."},"criticalityTier":{"type":"string","enum":["tier-1","tier-2","tier-3"],"description":"Criticality tier for dynamic defaults calculation (tier-1=mission-critical, tier-3=low-priority)."}},"required":["repositoryPath"],"$schema":"http://json-schema.org/draft-07/schema#"},"toolReferenceName":"appmod_plan_generate_dockerfile","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true"},{"name":"appmod_run_in_terminal","tags":["appmod","codetocloud"],"displayName":"@appmod run in terminal","modelDescription":"Run a command in a terminal.","inputSchema":{"type":"object","properties":{"workingDir":{"type":"string","description":"The working directory to run the command in."},"executable":{"type":"string","enum":["powershell","cmd"],"description":"The type of shell to run. If not provided, powershell will be used."},"commandToRun":{"type":"string","description":"The command to run in the terminal."},"env":{"type":"array","items":{"type":"object","properties":{"key":{"type":"string"},"value":{"type":"string"}},"required":["key","value"]},"description":"The environment variables to set for the command."}},"required":["workingDir","executable","commandToRun","env"]},"toolReferenceName":"appmod_run_in_terminal","canBeReferencedInPrompt":true,"when":"false"},{"name":"appmod_summarize_result","tags":["appmod","codetocloud"],"displayName":"@appmod summarize result","modelDescription":"This tool will summarize the Azure deployment result for Azure deployments. Call this tool ONLY when the deployment has been EXECUTED according to '.azure/plan.${COPILOT_MD_EXTENSION}'.","inputSchema":{"type":"object","properties":{"workspaceFolder":{"type":"string","description":"The full path of the workspace folder. Use '/' as path separator."},"projectName":{"type":"string","description":"The name of the project."},"deploymentStatus":{"type":"string","enum":["success","failure"],"description":"The final status of the deployment."},"createdFileNames":{"type":"array","items":{"type":"string"},"description":"List of files' name created during the deployment."},"deployOption":{"type":"string","enum":["deploy-only","provision-only","provision-and-deploy"],"description":"Keep this consistent with the deploy option or infer from the deployment plan. 'deploy-only' if user deployed to existing Azure resources. Use 'provision-only' if user only provisioned Azure resource. Use 'provision-and-deploy' if user created infra from scratch and deployed application."},"deploymentRounds":{"type":"number","description":"Number of rounds the deployment was executed until a successful deployment."},"provisionedResourceTypes":{"type":"array","items":{"type":"string"},"description":"Types of Azure resources provisioned during the deployment."},"deploymentTool":{"type":"string","enum":["azd","azcli"],"description":"The tool to use for provisioning Azure resources."},"iacOptions":{"anyOf":[{"type":"string","enum":["bicep","terraform"]},{"type":"string","const":""}],"description":"The Infrastructure as Code option. Leave empty if user wants to use azcli command script."},"subscriptionId":{"type":"string","description":"The Azure subscription ID where the resources were provisioned and apps were deployed."}},"required":["workspaceFolder","projectName","deploymentStatus","createdFileNames","deployOption","deploymentRounds","provisionedResourceTypes","deploymentTool","subscriptionId"]},"toolReferenceName":"appmod_summarize_result","canBeReferencedInPrompt":true,"when":"config.appmod.enableMcpServer != true"}],"commands":[{"command":"migrate.java.formula.refresh","title":"Refresh Task","icon":"$(refresh)","category":"GitHub Copilot modernization"},{"command":"migrate.java.formula.revealMySkills","title":"Show My Skills","category":"GitHub Copilot modernization"},{"command":"migrate.java.formula.create","title":"Create a Custom Skill","icon":"$(add)","category":"GitHub Copilot modernization"},{"command":"migrate.java.formula.edit","title":"Edit","icon":"$(edit)","category":"GitHub Copilot modernization"},{"command":"migrate.java.formula.run","title":"Run Skill","icon":"$(run)","category":"GitHub Copilot modernization"},{"command":"migrate.java.formula.delete","title":"Delete","icon":"$(trash)","category":"GitHub Copilot modernization"},{"command":"migrate.java.formula.deleteAll","title":"Delete","icon":"$(trash)","category":"GitHub Copilot modernization"},{"command":"migrate.java.formula.exportAsSkill","title":"Copy to My Skills","icon":"$(export)","category":"GitHub Copilot modernization"},{"command":"migrate.java.manageCustomSkills","title":"Skills Marketplace","icon":"$(extensions)","category":"GitHub Copilot modernization"},{"command":"migrate.assessment","title":"Run Assessment","icon":"$(run)","enablement":"assessmentEnabled","category":"GitHub Copilot modernization"},{"command":"migrate.assessment.configure","title":"Custom Assessment Configuration","icon":"$(settings-gear)","enablement":"assessmentEnabled","category":"GitHub Copilot modernization"},{"command":"migrate.java.assessment.abort","title":"Cancel Assessment","icon":"$(stop-circle)","category":"GitHub Copilot modernization"},{"command":"migrate.java.assessment.refresh","title":"Refresh Assessment","icon":"$(extensions-refresh)","enablement":"assessmentEnabled","category":"GitHub Copilot modernization"},{"command":"migrate.java.assessment.summaryReport","title":"Open Summary Report","icon":"$(run)","visible":"true","enablement":"assessmentEnabled","category":"GitHub Copilot modernization"},{"command":"migrate.java.openAssessmentList","title":"Open Assessment List","icon":"$(list-unordered)","category":"GitHub Copilot modernization"},{"command":"migrate.java.openAssessmentWelcome","title":"Open Assessment Welcome","icon":"$(list-unordered)","category":"GitHub Copilot modernization"},{"command":"migrate.java.assessment.summaryReport.delete","title":"Delete","icon":"$(trash)","visible":"true","enablement":"assessmentEnabled","category":"GitHub Copilot modernization"},{"command":"migrate.java.assessment.importFromLocal","title":"Import","icon":"$(icon-import)","visible":"true","enablement":"assessmentEnabled","category":"GitHub Copilot modernization"},{"command":"migrate.java.assessment.importFromLocalCommandPalette","title":"Import Assessment Report","icon":"$(icon-import)","category":"GitHub Copilot modernization"},{"command":"migrate.java.assessment.exportToLocal","title":"Export","icon":"$(export)","visible":"true","enablement":"assessmentEnabled","category":"GitHub Copilot modernization"},{"command":"migrate.java.assessment.exportToLocalCommandPalette","title":"Export Assessment Report","icon":"$(export)","category":"GitHub Copilot modernization"},{"command":"migrate.java.resource.documentation","title":"View Documentation","icon":"$(book)","category":"GitHub Copilot modernization"},{"command":"migrate.java.resource.reportIssues","title":"Report Issues on GitHub","icon":"$(github)","category":"GitHub Copilot modernization"},{"command":"migrate.java.resource.survey","title":"Feedback via a survey","icon":"$(feedback)","category":"GitHub Copilot modernization"},{"command":"migrate.java.appcat.install","title":"Install or Upgrade AppCAT for Java","icon":"$(desktop-download)","category":"GitHub Copilot modernization"},{"command":"migrate.dotnet.upgrade","title":"Upgrade to a newer version of .NET","icon":"assets/upgrade-dotnet.svg","category":"GitHub Copilot modernization"},{"command":"migrate.java.recommendMigrationTasks","title":"Recommend Migration Tasks","icon":"$(lightbulb)","category":"GitHub Copilot modernization"},{"command":"appmod.javaUpgrade.gotoAgentMode","title":"Goto Agent mode","category":"GitHub Copilot modernization"},{"command":"appmod.javaUpgrade.upgradeProject","title":"Upgrade Java Project","category":"GitHub Copilot modernization"},{"command":"appmod.javaUpgrade.upgradeJavaFramework","title":"Upgrade Java Framework","category":"GitHub Copilot modernization"},{"command":"appmod.javaUpgrade.generateUnitTests","title":"Generate Unit Tests","category":"GitHub Copilot modernization"},{"command":"appmod.javaUpgrade.runCveValidation","title":"Run Cve Validation","category":"GitHub Copilot modernization"}],"menus":{"commandPalette":[{"command":"migrate.java.formula.edit","when":"false"},{"command":"migrate.java.formula.run","when":"false"},{"command":"migrate.java.formula.delete","when":"false"},{"command":"migrate.java.formula.deleteAll","when":"false"},{"command":"migrate.java.assessment.summaryReport","when":"false"},{"command":"migrate.java.assessment.summaryReport.delete","when":"false"},{"command":"migrate.java.assessment.exportToLocal","when":"false"},{"command":"migrate.java.assessment.importFromLocal","when":"false"}],"view/title":[{"command":"migrate.java.formula.create","group":"navigation@1","when":"view == migrate.java.formulaTreeView"},{"command":"migrate.java.manageCustomSkills","group":"navigation@2","when":"view == migrate.java.formulaTreeView"},{"command":"migrate.java.formula.refresh","group":"navigation@3","when":"view == migrate.java.formulaTreeView"},{"command":"migrate.assessment","group":"navigation@1","when":"(view == azureJavaMigrationAssessmentWebView || view == migrate.java.assessmentWelcomeView) && (appmod.hasJavaProjectInWorkspace || appmod.hasDotNetProjectInWorkspace)"},{"command":"migrate.java.assessment.importFromLocal","group":"navigation@2","when":"view == azureJavaMigrationAssessmentWebView || view == migrate.java.assessmentWelcomeView"},{"command":"migrate.assessment.configure","group":"navigation@3","when":"(view == azureJavaMigrationAssessmentWebView || view == migrate.java.assessmentWelcomeView) && (appmod.hasJavaProjectInWorkspace || appmod.hasDotNetProjectInWorkspace)"},{"command":"migrate.java.assessment.refresh","group":"navigation@4","when":"view == azureJavaMigrationAssessmentWebView && !assessmentRunning || view == migrate.java.assessmentWelcomeView"}],"view/item/context":[{"command":"migrate.java.formula.run","when":"view == migrate.java.formulaTreeView && (viewItem == task || viewItem == msft-formula-group || viewItem == formula-group || viewItem == msft-formula || viewItem == formula || viewItem == msft-kb || viewItem == msft-kb-experimental || viewItem == custom-task)","group":"inline@1"},{"command":"migrate.java.formula.edit","when":"view == migrate.java.formulaTreeView && (viewItem == formula || viewItem == custom-task)","group":"navigation"},{"command":"migrate.java.formula.delete","when":"view == migrate.java.formulaTreeView && (viewItem == formula || viewItem == custom-task)","group":"3_delete"},{"command":"migrate.java.formula.deleteAll","when":"view == migrate.java.formulaTreeView && viewItem == formula-group","group":"3_delete"},{"command":"migrate.java.formula.exportAsSkill","when":"view == migrate.java.formulaTreeView && (viewItem == msft-formula-group || viewItem == msft-kb)","group":"navigation"}]},"configuration":{"type":"object","title":"Github Copilot modernization","properties":{"migrateJava.enableVerboseLogging":{"type":"boolean","default":true,"description":"Enable verbose logging for the extension. This will log more information to the Output tab and may help with troubleshooting issues.","markdownDescription":"Enable verbose logging for the extension. This will log more information to the **Output** tab and may help with troubleshooting issues.","deprecationMessage":"Deprecated. Please use `appmod.enableVerboseLogging` instead.","markdownDeprecationMessage":"**Deprecated**. Please use `appmod.enableVerboseLogging` instead."},"appmod.enableVerboseLogging":{"type":"boolean","default":true,"description":"Enable verbose logging for the extension. This will log more information to the Output tab and may help with troubleshooting issues.","markdownDescription":"Enable verbose logging for the extension. This will log more information to the **Output** tab and may help with troubleshooting issues."},"appmod.enableMcpServer":{"type":"boolean","default":false,"description":"Enable MCP server to run GitHub Copilot modernization tools if your org restricts the default VS Code tool."},"appmod.experimental.enableExperimentalTasks":{"type":"boolean","default":true,"description":"Enable display of experimental tasks."},"appmod.experimental.task.rearchitecture":{"type":"boolean","default":false,"description":"Enable preview (experimental/early-access) feature for rearchitecture tasks. Preview features may change or be removed at any time."},"appmod.javaUpgrade.minimumCVESeverity":{"type":"string","default":"high","enum":["critical","high","medium","low"],"enumItemLabels":["Critical","High","Medium","Low"],"enumDescriptions":["Report and fix critical severity CVEs only","Report and fix high and critical severity CVEs","Report and fix medium, high, and critical severity CVEs","Report and fix all CVEs (low, medium, high, and critical severity)"],"markdownDescription":"Controls the minimum severity of CVE issues to be reported and fixed. CVEs at or above this severity level will be included."},"appmod.javaUpgrade.uncommittedChangesAction":{"type":"string","default":"Always Stash","enum":["Always Ask","Always Stash","Always Commit","Always Discard"],"enumDescriptions":["Prompt user for a decision on how to handle uncommitted changes","Stash (temporarily store) all uncommitted changes for later retrieval","Commit all uncommitted changes to the current branch.","Discard all uncommitted changes (warning: discard action is irreversible)."],"markdownDescription":"Controls how uncommitted changes should be handled (A clean working tree without uncommitted changes is required to modernize (migrate/upgrade) a project)."},"appmod.javaUpgrade.commandTimeout":{"type":"number","default":3600,"description":"The timeout in seconds for a command to complete."},"appmod.javaUpgrade.enableQuickPick":{"type":"boolean","default":false,"description":"Controls whether to show a quick pick dialog to ask user to pick a solution (when available) when there are required configuration invalid. If set to false, VSCode Copilot Agent is required to handle the invalidation."}}},"viewsContainers":{"activitybar":[{"id":"azureJavaMigrationExplorer","title":"GitHub Copilot modernization","icon":"assets/logo.svg"}]},"views":{"azureJavaMigrationExplorer":[{"id":"migrate.java.quickStartWelcomeView","name":"QuickStart","type":"webview"},{"id":"migrate.java.formulaTreeView","name":"Tasks"},{"id":"migrate.java.helpFeedbackView","name":"Help and Feedback","visibility":"collapsed","type":"tree"}]},"walkthroughs":[{"id":"javaAppModernization","title":"Modernize with Copilot","description":"Modernize your app quickly and confidently with agentic AI on your side.","steps":[{"id":"discoverExtension","title":"Discover the modernization extension","description":"Open the extension sidebar to start modernizing your app.\n[Open GitHub Copilot modernization](command:workbench.view.extension.azureJavaMigrationExplorer)","media":{"image":"assets/media/walkthrough/discover-extension.gif","altText":"Discover the modernization extension"},"completionEvents":["onCommand:workbench.view.extension.azureJavaMigrationExplorer"]},{"id":"chooseModernizationPath","title":"Choose your modernization path","description":"Assess your app and choose a modernization path based on your language and goals.\n\n**Assessment**\nAnalyze your app to identify compatibility issues, risks, and recommended modernization actions.\n\n**Java**\n- Runtime & Frameworks Upgrades: Automatically update your app to the latest Java versions and frameworks.\n- Migrate to Azure: Analyze your Java app, identify potential migration issues, and get solutions before you migrate.\n\n**.NET**\n- Modernize to .Net: Upgrade your app to the latest .Net versions for better performance and long-term support.\n- Prepare for cloud: Identify compatibility issues and get your app ready for Azure deployment.\n\n**Python**\n- Convert to Agent Framework: Convert your Python app (Semantic Kernel or AutoGen) to Agent Framework.\n\nTip: Have a clear goal? Type it in [chat](command:migrate.java.runInAgentMode) and run it.","media":{"image":"assets/media/walkthrough/choose-path.gif","altText":"Choose your modernization path for Java apps"},"completionEvents":["onCommand:migrate.java.runInAgentMode"]},{"id":"exploreAgenticTasks","title":"Explore more agentic tasks","description":"Explore a curated list of agentic tasks covering upgrades, migrations, quality and security checks, deployments, and more. Pick what fits your app and run it with ease.\n[View Tasks](command:migrate.java.formulaTreeView.focus)","media":{"image":"assets/media/walkthrough/explore-tasks.gif","altText":"Explore More Agentic Tasks"},"completionEvents":["onCommand:migrate.java.formulaTreeView.focus"]},{"id":"discoverMore","title":"Discover more","description":"Try the full set of modernization experience in the extension. For more details, check our documentation or just ask in the [chat](command:migrate.java.runInAgentMode).\n[Open Documentation](command:migrate.java.resource.documentation)","media":{"svg":"assets/media/walkthrough/explore-more.svg","altText":"Discover More"},"completionEvents":["onCommand:migrate.java.resource.documentation"]}]}]},"main":"./out/extension.js","scripts":{"prepare":"husky","build-mcp-server":"npm --workspace mcp-server run build","package-mcp-server":"npm --workspace mcp-server run package","benchmark-regenerate-all":"node test/regenerate-all.cjs","dependency-cve-report-msbench":"jest test/dependency-cve-report-msbench.test.ts","copilot-auth":"node scripts/copilot-auth.js","check-rules":"node scripts/check-rule-mapping.js","compile":"npm run build-mcp-server && npx tsc --project tsconfig.json","watch":"npm run build-mcp-server && npm run compile && node esbuild.js","build":"npm run build-mcp-server && npm run compile && node esbuild.js","package":"npm run package-mcp-server && npm run compile && node esbuild.js --production","vscode:prepublish":"npm run package","ut":"jest --testMatch \"<rootDir>/src/**/*.test.ts\" \"<rootDir>/mcp-server/src/**/*.test.ts\" --coverage","lint":"eslint .","lint-fix":"eslint . --fix"},"devDependencies":{"@babel/core":"^7.26.10","@babel/plugin-syntax-decorators":"^7.25.9","@babel/preset-env":"^7.26.0","@babel/prese