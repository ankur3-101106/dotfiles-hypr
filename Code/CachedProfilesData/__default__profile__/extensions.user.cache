d":"github.codespaces.switchUserAccount","title":"Switch User Account","category":"Codespaces"}],"menus":{"ports/item/context":[{"command":"github.codespaces.labelPortAndUpdateConfig","group":"0_manage@4","when":"tunnelType == Forwarded && remoteName == codespaces"}],"view/title":[{"command":"github.codespaces.addEnvironment","group":"navigation@1","when":"view == github.codespaces.explorer && codespaces:explorerState == Initialized && remoteName != codespaces"},{"command":"github.codespaces.refresh","group":"navigation@3","when":"view == github.codespaces.explorer && codespaces:explorerState == Initialized && remoteName != codespaces"},{"command":"github.codespaces.configureDevContainerSidebar","when":"view == github.codespaces.explorer && remoteName == codespaces","group":"navigation@1"},{"command":"github.codespaces.rebuildEnvironment","when":"view == github.codespaces.explorer && remoteName == codespaces","group":"navigation@2"},{"command":"github.codespaces.disconnectEnvironment","when":"view == github.codespaces.explorer && remoteName == codespaces","group":"navigation@3"}],"view/item/context":[{"command":"github.codespaces.disconnectEnvironment","when":"view == github.codespaces.explorer && viewItem =~ /disconnectFromEnabled/","group":"inline"},{"command":"github.codespaces.shutdownEnvironment","when":"view == github.codespaces.explorer && viewItem =~ /shutdownEnabled/","group":"inline"},{"command":"github.codespaces.connect","when":"!isWeb && view == github.codespaces.explorer && viewItem =~ /connectToEnabled/ || remoteName != codespaces && view == github.codespaces.explorer && viewItem =~ /connectToEnabled/","group":"inline"},{"command":"github.codespaces.removePath","when":"view == github.codespaces.explorer && viewItem =~ /removePathEnabled/","group":"inline"},{"command":"github.codespaces.connect","when":"!isWeb && view == github.codespaces.explorer && viewItem =~ /connectToEnabled/ || remoteName != codespaces && view == github.codespaces.explorer && vie