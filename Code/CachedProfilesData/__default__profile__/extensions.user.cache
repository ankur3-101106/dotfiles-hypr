,"configuration":{"type":"object","title":"Easy CodeSnap","properties":{"easy-codesnap.lockOnOpen":{"scope":"resource","type":"boolean","default":false,"markdownDescription":"Locks the snap screen on open. Locked screens do not respond to selection changes.","order":1},"easy-codesnap.linkOnOpen":{"scope":"resource","type":"boolean","default":false,"markdownDescription":"Links the snap screen to the editor on open. Linked screens respond only to selection changes within the active editor.","order":2},"easy-codesnap.performShutterActionOnOpen":{"scope":"resource","type":"boolean","default":false,"markdownDescription":"Automatically performs the configured shutter action when the snap screen opens.","order":3},"easy-codesnap.shutterAction":{"scope":"resource","type":"string","enum":["copy","save"],"default":"copy","markdownDescription":"Controls the behavior of the shutter button when taking a snapshot.","markdownEnumDescriptions":["Copies the snapshot to the clipboard.","Stores the snapshot to a file."],"order":4},"easy-codesnap.shutterActionAnimation":{"scope":"resource","type":"string","enum":["flash","shutter","colored-shutter"],"default":"flash","markdownDescription":"Controls the animation effect used when the shutter button is clicked.","markdownEnumDescriptions":["Applies a quick flash effect to indicate that a snapshot has been taken.","Applies a shutter closing and opening animation effect to indicate that a snapshot has been taken.","Applies a colored shutter closing and opening animation effect to indicate that a snapshot has been taken. The color matches the extension shutter icon."],"order":5},"easy-codesnap.saveFormat":{"scope":"resource","type":"string","enum":["png","svg","webp"],"default":"png","markdownDescription":"Specifies the file format for saving snapshots.","markdownEnumDescriptions":["Stores the snapshot in PNG format as a lossless bitmap image that supports transparency.","Stores the snapshot in SVG format as a vector image that can be scaled without quality loss.","Stores the snapshot in WEBP format as a bitmap image that provides efficient compression for smaller file sizes."],"order":6},"easy-codesnap.saveScale":{"scope":"resource","type":"number","enum":[0.5,0.75,1,1.5,2,3,4],"default":1,"markdownDescription":"Controls the scale to use when saving snapshots in PNG format.","markdownEnumDescriptions":["Scales the snapshot to 50% of the original size.","Scales the snapshot to 75% of the original size.","Keeps the snapshot at its original size (100%).","Scales the snapshot to 150% of the original size.","Scales the snapshot to 200% of the original size.","Scales the snapshot to 300% of the original size.","Scales the snapshot to 400% of the original size."],"order":7},"easy-codesnap.optimizeSvg":{"scope":"resource","type":"boolean","default":true,"markdownDescription":"Controls whether the svg should be optimized before saving. Only valid when [Easy-codesnap: Save Format](command:workbench.action.openSettings?%22@id:easy-codesnap.saveFormat%22) is set to `svg`.","order":8},"easy-codesnap.useFallbackPngExporter":{"scope":"resource","type":"boolean","default":false,"markdownDescription":"Controls whether the fallback PNG exporter is used as the primary exporter when saving snapshots in PNG format. Useful when the default exporter produces unexpected results.","order":9},"easy-codesnap.showLineNumbers":{"scope":"resource","type":"boolean","default":true,"markdownDescription":"Displays line numbers in the snap screen.","order":10},"easy-codesnap.realLineNumbers":{"scope":"resource","type":"boolean","default":false,"markdownDescription":"Displays actual line numbers from the selection instead of starting at 1. Only valid when [Easy-codesnap: Show Line Numbers](command:workbench.action.openSettings?%22@id:easy-codesnap.showLineNumbers%22) is enabled.","order":11},"easy-codesnap.highlightLineNumber":{"scope":"resource","type":"boolean","default":false,"markdownDescription":"Highlights the active line number using the `editorLineNumber-activeForeground` theme color. Only valid when [Easy-codesnap: Show Line Numbers](command:workbench.action.openSettings?%22@id:easy-codesnap.showLineNumbers%22) is enabled.","order":12},"easy-codesnap.fullLinesSelection":{"scope":"resource","type":"boolean","default":false,"markdownDescription":"Extends the selection to entire lines when opening the snap screen.","order":13},"easy-codesnap.windowStyle":{"scope":"resource","type":"string","enum":["macos","windows"],"default":"macos","markdownDescription":"Controls the window style for the snap screen.","markdownEnumDescriptions":["Applies macOS style to the snap screen with traffic light buttons.","Applies Windows style to the snap screen with standard window decorations."],"order":14},"easy-codesnap.windowIconType":{"scope":"resource","type":"string","enum":["round","square"],"default":"round","markdownDescription":"Controls the window icon style. Only valid when [Easy-codesnap: Window Style](command:workbench.action.openSettings?%22@id:easy-codesnap.windowStyle%22) is set to `windows`.","markdownEnumDescriptions":["Displays round icons in the window.","Displays square icons in the window."],"order":15},"easy-codesnap.showWindowTitle":{"scope":"resource","type":"boolean","default":false,"markdownDescription":"Displays the snap screen window title.","order":16},"easy-codesnap.windowTitleTemplate":{"scope":"resource","type":"string","minLength":1,"default":"{workspace} - {fileName}","markdownDescription":"Defines a template for the snap screen window title. Supports {workspace}, {fileName}, and {relativeFolder} variables.","order":17},"easy-codesnap.showWindowControls":{"scope":"resource","type":"boolean","default":true,"markdownDescription":"Displays window controls styled according to the selected operating system.","order":18},"easy-codesnap.roundedCorners":{"scope":"resource","type":"boolean","default":true,"markdownDescription":"Controls whether the snap screen window has rounded corners.","order":19},"easy-codesnap.roundingLevel":{"scope":"resource","type":"number","enum":[1,2,3,4],"default":1,"markdownDescription":"Controls the border radius level of the snap container. Only valid when [Easy-codesnap: Rounded Corners](command:workbench.action.openSettings?%22@id:easy-codesnap.roundedCorners%22) is enabled.","markdownEnumDescriptions":["Applies small rounded corners to the snap container.","Applies medium rounded corners to the snap container.","Applies large rounded corners to the snap container.","Applies extra large rounded corners to the snap container."],"order":20},"easy-codesnap.target":{"scope":"resource","type":"string","enum":["container","window"],"default":"container","markdownDescription":"Specifies the capture target when taking a snapshot.","markdownEnumDescriptions":["Captures the window along with the container that surrounds it as the snapshot target.","Captures only the window with the code snippet, title, and buttons as the snapshot target."],"order":21},"easy-codesnap.boxShadow":{"scope":"resource","type":"string","default":"rgba(0, 0, 0, 0.55) 0px 20px 68px","markdownDescription":"Defines the CSS `box-shadow` property for the snap container.","order":22},"easy-codesnap.backgroundColor":{"scope":"resource","type":"string","default":"#abb8c3","markdownDescription":"Defines the background color of the snap container.","order":23},"easy-codesnap.containerPadding":{"scope":"resource","type":"string","default":"3em","markdownDescription":"Defines the padding of the snap container.","order":24},"easy-codesnap.transparentBackground":{"scope":"resource","type":"boolean","default":false,"markdownDescription":"Uses a transparent background for the container when taking the snapshot. Only valid when [Easy-codesnap: Target](command:workbench.action.openSettings?%22@id:easy-codesnap.target%22) is set to `container`.","order":25},"easy-codesnap.enableResizing":{"scope":"resource","type":"boolean","default":true,"markdownDescription":"Allows resizing of the snap container. When disabled, this also resets any previous size adjustments.","order":26},"easy-codesnap.enableSymbolBreadcrumb":{"scope":"resource","type":"boolean","default":false,"markdownDescription":"Controls whether the symbol breadcrumb is displayed in the snap screen.","order":27},"easy-codesnap.maxCharWidth":{"scope":"resource","type":"integer","minimum":0,"maximum":200,"default":0,"markdownDescription":"Specifies the maximum line width in characters. Set to `0` for no limit. Invalid values are ignored, and the last valid value is retained.","order":28},"easy-codesnap.aspect-ratio":{"scope":"resource","type":"string","enum":["none","1:1","4:5","9:16","16:9","1.91:1"],"default":"none","markdownDescription":"Controls the aspect ratio of the snapshot. Only valid when [Easy-codesnap: Target](command:workbench.action.openSettings?%22@id:easy-codesnap.target%22) is set to `container`.","markdownEnumDescriptions":["Applies no fixed aspect ratio to the snapshot.","Applies a 1:1 ratio to the snapshot (square format).","Applies a 4:5 ratio to the snapshot (portrait format).","Applies a 9:16 ratio to the snapshot (vertical format).","Applies a 16:9 ratio to the snapshot (widescreen format).","Applies a 1.91:1 ratio to the snapshot (landscape format)."],"order":29},"easy-codesnap.watermark":{"scope":"resource","type":"boolean","default":false,"markdownDescription":"Displays a watermark on the snapshot.","order":30},"easy-codesnap.defaultWatermarkText":{"scope":"resource","type":"string","default":"Made with Easy CodeSnap","markdownDescription":"Defines the default watermark text.","order":31},"easy-codesnap.watermarkPosition":{"scope":"resource","type":"string","enum":["top-left","top-right","bottom-left","bottom-right"],"default":"bottom-right","markdownDescription":"Controls the position of the watermark. Top positions are only available when [Easy-codesnap: Target](command:workbench.action.openSettings?%22@id:easy-codesnap.target%22) is set to `container`.","markdownEnumDescriptions":["Places the watermark at the top-left corner of the snapshot.","Places the watermark at the top-right corner of the snapshot.","Places the watermark at the bottom-left corner of the snapshot.","Places the watermark at the bottom-right corner of the snapshot."],"order":32},"easy-codesnap.keepOriginalIndentation":{"scope":"resource","type":"boolean","default":false,"markdownDescription":"Preserves the original indentation of the selected code when taking a snapshot. When disabled, leading spaces or tabs may be trimmed based on the selection.","order":33},"easy-codesnap.uiCustomColors":{"scope":"resource","type":"object","default":{"watermarkPositionInputSelectedBackgroud":"var(--vscode-focusBorder)"},"markdownDescription":"Controls whether custom UI color overrides are applied to the extension's settings panel.","properties":{"watermarkPositionInputSelectedBackgroud":{"type":"string","default":"var(--vscode-focusBorder)","description":"Defines the background color used for the selected Watermark Position input, improving visibility in themes with low contrast."}},"order":34}}}},"keywords":["CodeSnap","Screenshot","Screenshot Tool","Screenshot Extension","Code Snapshot","Polacode","Code Screenshot","snippet","share","carbon"],"scripts":{"vscode:prepublish":"npm run package","webpack":"webpack --mode development","webpack-dev":"webpack --mode development --watch","package":"yarn build:css && webpack --mode production","compile":"yarn run webpack","watch":"yarn webpack-dev","lint":"biome check","lint:fix":"biome check --write","translation-status":"tsx cli translation-status","compress-json":"tsx cli compress-json","make-badges":"tsx cli make-badges","sort":"tsx cli sort order && tsx cli sort nls","build:css":"tailwindcss -i ./webview/style.css -o ./webview/output.css -m"},"devDependencies":{"@biomejs/biome":"^2.3.6","@svgr/webpack":"^8.1.0","@types/node":"18.x","@types/react":"^19.1.8","@types/react-dom":"^19.1.6","@types/vscode"